<nav aria-label="Main navigation" role="navigation">
  <a href="/" class="nav-brand">
    <img src="/img/neuron-logo.jpg" alt="Neural NeXus" width="1024" height="1024" decoding="async">
    <span class="nav-brand-text">Neural<span>NeXus</span></span>
  </a>

  <ul class="nav-links">
    <li><a href="/" class="nav-link <% if (locals.activePage === 'home') { %>active<% } %>">Home</a></li>
    <li><a href="/topics/ai" class="nav-link <% if (locals.activePage === 'topics') { %>active<% } %>">Topics</a></li>
    <li><a href="/archive" class="nav-link <% if (locals.activePage === 'archive') { %>active<% } %>">Archive</a></li>
    <li><a href="/play" class="nav-link <% if (locals.activePage === 'games') { %>active<% } %>">Games</a></li>
    <li><a href="https://blog.neuralnexus.press/subscribe?utm_source=neuralnexus&utm_medium=nav&utm_campaign=site-nav" class="nav-cta <% if (locals.activePage === 'subscribe') { %>active<% } %>" target="_blank" rel="noopener noreferrer">Subscribe</a></li>
  </ul>

  <button class="nav-toggle" type="button" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-drawer">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
  </button>
</nav>

<div class="mobile-backdrop" hidden></div>
<aside id="mobile-drawer" class="mobile-drawer" aria-label="Mobile navigation" aria-hidden="true">
  <ul>
    <li><a href="/" class="<% if (locals.activePage === 'home') { %>active<% } %>">Home</a></li>
    <li><a href="/topics/ai" class="<% if (locals.activePage === 'topics') { %>active<% } %>">Topics</a></li>
    <li><a href="/archive" class="<% if (locals.activePage === 'archive') { %>active<% } %>">Archive</a></li>
    <li><a href="/play" class="<% if (locals.activePage === 'games') { %>active<% } %>">Games</a></li>
    <li><a href="https://blog.neuralnexus.press/subscribe?utm_source=neuralnexus&utm_medium=nav&utm_campaign=site-nav" target="_blank" rel="noopener noreferrer">Subscribe</a></li>
  </ul>
</aside>

<script>
  (() => {
    const toggle = document.querySelector('.nav-toggle');
    const drawer = document.getElementById('mobile-drawer');
    const backdrop = document.querySelector('.mobile-backdrop');
    if (!toggle || !drawer || !backdrop) return;

    const focusable = () => drawer.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])');

    function setOpen(open) {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
      drawer.classList.toggle('open', open);
      backdrop.classList.toggle('open', open);
      backdrop.hidden = !open;
      document.body.style.overflow = open ? 'hidden' : '';
      if (open) {
        const [first] = focusable();
        if (first) first.focus();
      } else {
        toggle.focus();
      }
    }

    toggle.addEventListener('click', () => setOpen(toggle.getAttribute('aria-expanded') !== 'true'));
    backdrop.addEventListener('click', () => setOpen(false));
    drawer.querySelectorAll('a').forEach(link => link.addEventListener('click', () => setOpen(false)));

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && drawer.classList.contains('open')) setOpen(false);
    });
  })();
</script>
