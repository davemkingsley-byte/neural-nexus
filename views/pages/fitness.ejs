async function refreshDietView() {
  const viewDate = document.getElementById('diet-view-date').value;
  const entries = await api.get('/api/fitness/diet?date=' + viewDate);
  const totals = entries.reduce((a,e) => ({ calories:a.calories+(e.calories||0), protein_g:a.protein_g+(e.protein_g||0), carbs_g:a.carbs_g+(e.carbs_g||0), fat_g:a.fat_g+(e.fat_g||0) }), { calories:0, protein_g:0, carbs_g:0, fat_g:0 });
  const targets = getDietTargets();
  const rings = document.getElementById('macro-rings');
  rings.innerHTML = `
    <div class="macro-ring"><canvas id="ring-c"></canvas><div class="lbl">Calories</div><div class="val">${Math.round(totals.calories)}/${targets.calories}</div></div>
    <div class="macro-ring"><canvas id="ring-p"></canvas><div class="lbl">Protein</div><div class="val">${Math.round(totals.protein_g)}/${targets.protein_g}g</div></div>
    <div class="macro-ring"><canvas id="ring-k"></canvas><div class="lbl">Carbs</div><div class="val">${Math.round(totals.carbs_g)}/${targets.carbs_g}g</div></div>
    <div class="macro-ring"><canvas id="ring-f"></canvas><div class="lbl">Fat</div><div class="val">${Math.round(totals.fat_g)}/${targets.fat_g}g</div></div>
  `;
  renderMacroRing(document.getElementById('ring-c'), totals.calories, targets.calories, '', '#60a5fa');
  renderMacroRing(document.getElementById('ring-p'), totals.protein_g, targets.protein_g, '', '#34d399');
  renderMacroRing(document.getElementById('ring-k'), totals.carbs_g, targets.carbs_g, '', '#fbbf24');
  renderMacroRing(document.getElementById('ring-f'), totals.fat_g, targets.fat_g, '', '#f87171');

  const ent = document.getElementById('diet-entries');
  if (!entries.length) { ent.innerHTML = '<div class="muted">No entries for this date.</div>'; return; }
  const byMeal = {};
  entries.forEach(e => { (byMeal[e.meal || 'Other'] ||= []).push(e); });
  ent.innerHTML = Object.entries(byMeal).map(([meal, list]) => {
    const mTotals = list.reduce((a,e) => ({ c: a.c + (e.calories||0), p: a.p + (e.protein_g||0), k: a.k + (e.carbs_g||0), f: a.f + (e.fat_g||0) }), { c:0, p:0, k:0, f:0 });
    return `
    <h3>${escapeHtml(meal)} <span class="muted" style="font-weight:400;">— ${Math.round(mTotals.c)} kcal / ${Math.round(mTotals.p)}P / ${Math.round(mTotals.k)}C / ${Math.round(mTotals.f)}F</span>
      <button class="f-btn secondary small" data-save-goto="${encodeURIComponent(meal)}" style="margin-left:6px;">★ Save as go-to</button>
    </h3>
    <div class="table-wrap"><table><thead><tr><th>Food</th><th>Cal</th><th>P</th><th>C</th><th>F</th><th></th></tr></thead>
    <tbody>${list.map(e => `
      <tr data-entry-id="${e.id}"><td>${escapeHtml(e.food)}</td><td>${e.calories ?? ''}</td><td>${e.protein_g ?? ''}</td><td>${e.carbs_g ?? ''}</td><td>${e.fat_g ?? ''}</td>
      <td><button class="f-btn danger small" data-del-diet="${e.id}">×</button></td></tr>`).join('')}</tbody></table></div>
  `;}).join('');
  ent.querySelectorAll('[data-del-diet]').forEach(btn => {
    btn.addEventListener('click', async () => {
      await api.del('/api/fitness/diet/' + btn.dataset.delDiet);
      refreshDietView();
    });
  });
  ent.querySelectorAll('[data-save-goto]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const meal = decodeURIComponent(btn.dataset.saveGoto);
      const list = byMeal[meal];
      const defaultName = `${meal} — ${viewDate}`;
      const name = prompt('Save this meal as a go-to. Name:', defaultName);
      if (!name) return;
      const items = list.map(e => ({
        food_id: e.food_id || null,
        food_name: e.food.replace(/^\d+(\.\d+)?×\s*/, ''), // strip leading "2× " if present
        servings: e.servings || 1,
        calories: (e.calories || 0) / (e.servings || 1),
        protein_g: (e.protein_g || 0) / (e.servings || 1),
        carbs_g: (e.carbs_g || 0) / (e.servings || 1),
        fat_g: (e.fat_g || 0) / (e.servings || 1)
      }));
      await api.post('/api/fitness/goto-meals', { name, meal, items });
      renderGoToMeals();
    });
  });
}

