// ---- Food search ----
document.getElementById('food-search').addEventListener('input', (e) => {
  clearTimeout(searchTimer);
  const q = e.target.value.trim();
  searchTimer = setTimeout(() => runFoodSearch(q), 180);
});
document.getElementById('food-search').addEventListener('focus', () => {
  const q = document.getElementById('food-search').value.trim();
  runFoodSearch(q);
});
document.addEventListener('click', (e) => {
  if (!e.target.closest('#food-search') && !e.target.closest('#food-search-results')) {
    document.getElementById('food-search-results').classList.remove('open');
  }
});

function sourceBadge(source, category) {
  const lbl = source === 'openfoodfacts' ? 'Grocery' : source === 'nutritionix' ? (category === 'restaurant' ? 'Restaurant' : 'Branded') : source === 'custom' ? 'Custom' : 'USDA';
  const cls = source === 'openfoodfacts' ? 'openfoodfacts' : source === 'nutritionix' ? (category === 'restaurant' ? 'restaurant' : 'nutritionix') : source === 'custom' ? 'custom' : 'usda';
  return `<span class="source-badge ${cls}">${lbl}</span>`;
}

async function runFoodSearch(q) {
  const resultsEl = document.getElementById('food-search-results');
  const myReq = ++searchSeq;
  try {
    const { results, nutritionix_configured } = await api.get('/api/fitness/foods?q=' + encodeURIComponent(q));
    if (myReq !== searchSeq) return; // a newer search superseded this one
    if (!results.length) {
      resultsEl.innerHTML = `<div class="food-result muted">No matches. ${nutritionix_configured ? '' : 'Configure NUTRITIONIX_APP_ID + NUTRITIONIX_APP_KEY in .env for restaurant coverage. '}Or use manual entry below.</div>`;
      resultsEl.classList.add('open');
      return;
    }
    // Group: local first, then online sources
    const local = results.filter(r => r.source !== 'openfoodfacts' && r.source !== 'nutritionix');
    const off = results.filter(r => r.source === 'openfoodfacts');
    const nix = results.filter(r => r.source === 'nutritionix');

    const renderItem = (r, i) => `
      <div class="food-result" data-idx="${i}">
        <div class="title">${escapeHtml(r.name)} ${sourceBadge(r.source, r.category)}</div>
        <div class="sub">${r.category && r.category !== 'restaurant' && r.category !== 'branded' ? escapeHtml(r.category) + ' · ' : ''}${r.serving_description ? escapeHtml(r.serving_description) : 'per serving'}</div>
        <div class="macros">${r.calories ?? '?'} kcal · P ${r.protein_g ?? '?'}g · C ${r.carbs_g ?? '?'}g · F ${r.fat_g ?? '?'}g</div>
      </div>
    `;

    let html = '';
    let i = 0;
    if (local.length) { html += local.map(r => renderItem(r, i++)).join(''); }
    if (off.length) { html += `<div class="food-section-header">📦 Branded groceries (Open Food Facts)</div>` + off.map(r => renderItem(r, i++)).join(''); }
    if (nix.length) {
      const hasRestaurant = nix.some(r => r.category === 'restaurant');
      html += `<div class="food-section-header">${hasRestaurant ? '🍽️ Restaurants & branded' : '🏷️ Branded'} (Nutritionix)</div>` + nix.map(r => renderItem(r, i++)).join('');
    }
    if (!nutritionix_configured && !nix.length) {
      html += `<div class="food-section-header muted" style="font-style:italic;">🍽️ Restaurant data: set NUTRITIONIX_APP_ID + NUTRITIONIX_APP_KEY in .env to enable</div>`;
    }

    // Flatten ordered results to match indices
    const ordered = [...local, ...off, ...nix];
    resultsEl.innerHTML = html;
    resultsEl.classList.add('open');
    resultsEl.querySelectorAll('.food-result').forEach(el => el.addEventListener('click', async () => {
      const r = ordered[+el.dataset.idx];
      await selectFoodFromResult(r);
    }));
  } catch (err) {
    if (myReq !== searchSeq) return;
    resultsEl.innerHTML = `<div class="food-result muted">Search failed: ${escapeHtml(err.message || err)}</div>`;
    resultsEl.classList.add('open');
  }
}

// Intercept external-source results: import into local DB first so we get a real id
async function selectFoodFromResult(r) {
  if (r.source === 'openfoodfacts' || r.source === 'nutritionix') {
    const imported = await api.post('/api/fitness/foods/import', {
      name: r.name,
      category: r.category,
      source: r.source,
      external_id: r.external_id,
      serving_description: r.serving_description,
      serving_size_g: r.serving_size_g,
      calories_per_100g: r.per100g?.calories,
      protein_per_100g: r.per100g?.protein_g,
      carbs_per_100g: r.per100g?.carbs_g,
      fat_per_100g: r.per100g?.fat_g
    });
    if (imported.error) { alert('Import failed: ' + imported.error); return; }
    r.id = imported.id;
  }
  selectFood(r);
}

function selectFood(food) {
  // Normalize: recent-foods entries don't have per100g but do have flat calories/P/C/F
  selectedFood = {
    id: food.id > 0 ? food.id : null,
    name: food.name,
    serving_description: food.serving_description || null,
    serving_size_g: food.serving_size_g || null,
    base: {
      calories: food.calories ?? 0,
      protein_g: food.protein_g ?? 0,
      carbs_g: food.carbs_g ?? 0,
      fat_g: food.fat_g ?? 0
    }
  };
  document.getElementById('food-search-results').classList.remove('open');
  document.getElementById('food-search').value = '';
  document.getElementById('food-selected').style.display = 'block';
  document.getElementById('food-selected-name').textContent = `${food.name}${food.serving_description ? ' — ' + food.serving_description : ''}`;
  document.getElementById('food-servings').value = 1;
  updateFoodPreview();
}

function updateFoodPreview() {
  if (!selectedFood) return;
  const s = parseFloat(document.getElementById('food-servings').value) || 1;
  const b = selectedFood.base;
  document.getElementById('food-preview').textContent =
    `${Math.round(b.calories * s)} kcal · P ${Math.round(b.protein_g * s * 10)/10}g · C ${Math.round(b.carbs_g * s * 10)/10}g · F ${Math.round(b.fat_g * s * 10)/10}g`;
}

document.getElementById('food-servings').addEventListener('input', updateFoodPreview);
document.getElementById('food-cancel').addEventListener('click', () => {
  selectedFood = null;
  document.getElementById('food-selected').style.display = 'none';
});
document.getElementById('food-log').addEventListener('click', async (e) => {
  if (!selectedFood) return;
  const btn = e.currentTarget;
  if (btn.disabled) return;
  btn.disabled = true;
  try {
    const date = document.getElementById('diet-date').value || today();
    const meal = document.getElementById('diet-meal').value;
    const s = parseFloat(document.getElementById('food-servings').value) || 1;
    const b = selectedFood.base;
    const foodName = s === 1 ? selectedFood.name : `${s}× ${selectedFood.name}`;
    const r = await api.post('/api/fitness/diet', {
      date, meal, food: foodName,
      calories: Math.round(b.calories * s),
      protein_g: Math.round(b.protein_g * s * 10) / 10,
      carbs_g: Math.round(b.carbs_g * s * 10) / 10,
      fat_g: Math.round(b.fat_g * s * 10) / 10,
      food_id: selectedFood.id,
