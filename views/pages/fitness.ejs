<style>
body.fitness-page { background:#06060b; color:#f0f0f5; font-family: system-ui, -apple-system, sans-serif; -webkit-font-smoothing: antialiased; min-height: 100vh; margin:0; padding:0; }
body.fitness-page * { box-sizing:border-box; }
body.fitness-page .ambient { position:fixed; inset:0; pointer-events:none; z-index:0; }
body.fitness-page .ambient::before, body.fitness-page .ambient::after { content:''; position:absolute; pointer-events:none; }
body.fitness-page .ambient::before { top:-15%; left:5%; width:500px; height:500px; background:radial-gradient(circle, rgba(96,165,250,0.06) 0%, transparent 70%); }
body.fitness-page .ambient::after { bottom:-10%; right:5%; width:400px; height:400px; background:radial-gradient(circle, rgba(167,139,250,0.05) 0%, transparent 70%); }

.fitness-app { --bg:#06060b; --surface:rgba(255,255,255,0.03); --surface-2:rgba(255,255,255,0.06); --surface-3:rgba(255,255,255,0.09); --border:rgba(255,255,255,0.08); --border-2:rgba(255,255,255,0.15); --text:#f0f0f5; --text-dim:rgba(255,255,255,0.4); --text-mid:rgba(255,255,255,0.65); --accent:#60a5fa; --accent-2:#a78bfa; --green:#34d399; --red:#f87171; --yellow:#fbbf24; --gold:#f0c040; position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 16px; color: var(--text); }

.fitness-app .f-hero { display:flex !important; flex-direction:row !important; align-items:center !important; justify-content:space-between !important; gap:12px; padding:8px 4px 16px !important; border-bottom:1px solid var(--border); margin:0 0 16px !important; max-width:none !important; min-height:0 !important; text-align:left !important; flex-wrap:wrap; }
.fitness-app .f-hero h1 { font-family: system-ui, -apple-system, sans-serif !important; font-size: clamp(1.2rem, 4vw, 1.6rem) !important; font-weight:700 !important; letter-spacing:-0.02em; margin:0 !important; line-height:1.2 !important; }
.fitness-app .f-hero .f-logo { background:linear-gradient(135deg, var(--accent), var(--accent-2)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.fitness-app .f-hero .back-link { font-size: 0.85rem; color: var(--text-dim); text-decoration:none; padding:8px 12px; border:1px solid var(--border); border-radius:8px; }
.fitness-app .f-hero .back-link:hover { color: var(--text); border-color: var(--border-2); }

.fitness-app .tabs { position: sticky; top: 0; z-index:10; background:rgba(6,6,11,0.92); backdrop-filter: blur(20px); border-bottom:1px solid var(--border); margin:0 -16px 20px; padding: 4px 16px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
.fitness-app .tabs ul { list-style:none; display:flex; gap:4px; min-width: max-content; margin:0; padding:0; }
.fitness-app .tab-btn { background:none; border:none; color: var(--text-dim); padding:12px 16px; font-size:0.9rem; cursor:pointer; border-bottom: 2px solid transparent; min-height:48px; white-space:nowrap; font-family:inherit; }
.fitness-app .tab-btn.active { color: var(--text); border-bottom-color: var(--accent); }
.fitness-app .tab-btn:hover { color: var(--text); }

.fitness-app .panel { display:none; }
.fitness-app .panel.active { display:block; animation: f-fadeIn 0.2s; }
@keyframes f-fadeIn { from { opacity:0; transform: translateY(4px); } to { opacity:1; transform: translateY(0); } }

.fitness-app .f-card { background: var(--surface); border:1px solid var(--border); border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.fitness-app .f-card h2 { font-family: system-ui, -apple-system, sans-serif; font-size:1rem; font-weight:600; margin:0 0 12px; display:flex; align-items:center; gap:8px; color: var(--text); }
.fitness-app .f-card h3 { font-family: system-ui, -apple-system, sans-serif; font-size:0.9rem; font-weight:600; margin:0 0 8px; color: var(--text-mid); }

.fitness-app .grid-2 { display:grid; grid-template-columns: 1fr; gap:16px; }
@media (min-width: 700px) { .fitness-app .grid-2 { grid-template-columns: 1fr 1fr; } }

.fitness-app .status-row { display:flex; gap:8px; flex-wrap:wrap; }
.fitness-app .status-chip { flex:1 1 100px; min-width:100px; padding:10px 12px; border-radius:10px; border:1px solid var(--border); background: var(--surface-2); }
.fitness-app .status-chip .lbl { font-size:0.7rem; color: var(--text-dim); text-transform:uppercase; letter-spacing:0.05em; }
.fitness-app .status-chip .val { font-size:1.1rem; font-weight:600; margin-top:4px; }
.fitness-app .status-chip.ok { border-color: rgba(52,211,153,0.3); }
.fitness-app .status-chip.ok .val { color: var(--green); }
.fitness-app .status-chip.no { border-color: rgba(248,113,113,0.2); }
.fitness-app .status-chip.no .val { color: var(--red); }

.fitness-app .form-row { display:flex; gap:8px; flex-wrap:wrap; align-items:flex-end; margin-bottom:10px; }
.fitness-app .form-field { display:flex; flex-direction:column; gap:4px; flex:1; min-width: 100px; }
.fitness-app .form-field label { font-size:0.75rem; color: var(--text-dim); text-transform:uppercase; letter-spacing:0.04em; }
.fitness-app input[type=text], .fitness-app input[type=number], .fitness-app input[type=date], .fitness-app input[type=file], .fitness-app select, .fitness-app textarea {
  background: var(--surface-2); border:1px solid var(--border); color: var(--text); border-radius: 8px; padding: 10px 12px; font-size: 1rem; font-family: inherit; min-height: 44px;
}
.fitness-app input:focus, .fitness-app select:focus, .fitness-app textarea:focus { outline:none; border-color: var(--accent); background: var(--surface-3); }
.fitness-app textarea { resize: vertical; min-height: 60px; }

.fitness-app button.f-btn { background: var(--accent); color: #06060b; border:none; border-radius:8px; padding: 10px 16px; font-size: 0.95rem; font-weight:600; cursor:pointer; min-height:44px; font-family: inherit; }
.fitness-app button.f-btn:hover { background: #7cb8ff; }
.fitness-app button.f-btn.secondary { background: var(--surface-2); color: var(--text); border:1px solid var(--border); }
.fitness-app button.f-btn.secondary:hover { background: var(--surface-3); border-color: var(--border-2); }
.fitness-app button.f-btn.danger { background: rgba(248,113,113,0.15); color: var(--red); border:1px solid rgba(248,113,113,0.3); }
.fitness-app button.f-btn.small { padding:6px 10px; font-size: 0.8rem; min-height: 32px; }

.fitness-app .chart-wrap { position: relative; height: 240px; }
.fitness-app canvas { max-width:100%; }

.fitness-app table { width:100%; border-collapse: collapse; font-size: 0.9rem; }
.fitness-app th, .fitness-app td { text-align:left; padding: 8px 6px; border-bottom: 1px solid var(--border); }
.fitness-app th { color: var(--text-dim); font-weight:500; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.04em; }
.fitness-app tbody tr:hover { background: var(--surface-2); }
.fitness-app .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
.fitness-app .table-wrap table { min-width: 420px; }

.fitness-app .history-list { display:flex; flex-direction:column; gap:8px; }
.fitness-app .hist-item { background: var(--surface-2); border:1px solid var(--border); border-radius:10px; padding:12px; cursor:pointer; }
.fitness-app .hist-item:hover { border-color: var(--border-2); }
.fitness-app .hist-head { display:flex; justify-content:space-between; gap:8px; flex-wrap:wrap; }
.fitness-app .hist-date { font-weight:600; font-size:0.95rem; }
.fitness-app .hist-meta { color: var(--text-dim); font-size:0.8rem; }
.fitness-app .hist-sets { display:none; margin-top:10px; padding-top:10px; border-top:1px solid var(--border); }
.fitness-app .hist-item.expanded .hist-sets { display:block; }
.fitness-app .pr-badge { color: var(--gold); font-size: 0.8em; }

.fitness-app .session-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 12px; padding: 14px; margin-bottom: 12px; }
.fitness-app .session-card .head { display:flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
.fitness-app .session-card .session-date { font-weight: 600; font-size: 1rem; }
.fitness-app .session-card .session-stats { display:flex; gap: 12px; font-family: ui-monospace, monospace; font-size: 0.8rem; color: var(--text-mid); flex-wrap: wrap; }
.fitness-app .session-card .session-stats span { padding: 2px 8px; background: var(--surface-3); border-radius: 4px; }
.fitness-app .session-angles { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
.fitness-app .session-angle { position: relative; aspect-ratio: 3/4; border-radius: 6px; overflow: hidden; cursor: pointer; border: 1px solid var(--border); }
.fitness-app .session-angle img { width: 100%; height: 100%; object-fit: cover; }
.fitness-app .session-angle .label { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); color: white; text-align: center; padding: 8px 4px 3px; font-size: 0.65rem; text-transform: uppercase; }
.fitness-app .session-assessment { margin-top: 10px; padding: 10px; background: var(--surface-3); border-radius: 8px; font-size: 0.85rem; color: var(--text-mid); line-height: 1.5; }
.fitness-app .photo-grid { display:grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap:10px; }
.fitness-app .photo-card { position:relative; aspect-ratio: 3/4; border-radius:10px; overflow:hidden; border:1px solid var(--border); background: var(--surface-2); cursor:pointer; }
.fitness-app .photo-card img { width:100%; height:100%; object-fit: cover; }
.fitness-app .photo-date { position:absolute; bottom:0; left:0; right:0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); color:white; padding: 14px 8px 6px; font-size:0.75rem; font-weight:600; }
.fitness-app .photo-card.compare-pick { outline: 3px solid var(--accent); }
.fitness-app .session-angle.compare-pick { outline: 3px solid var(--accent); outline-offset: -1px; }
.fitness-app .ai-badge { position:absolute; top:6px; right:6px; background: rgba(52,211,153,0.2); color: var(--green); border:1px solid var(--green); font-size: 0.65rem; padding: 2px 6px; border-radius: 4px; }

.f-modal { position:fixed; inset:0; background:rgba(0,0,0,0.8); display:flex; align-items:center; justify-content:center; z-index:100; padding:16px; }
.f-modal-content { background: #06060b; border:1px solid rgba(255,255,255,0.15); border-radius:12px; max-width:900px; width:100%; max-height: 90vh; overflow:auto; padding:20px; color:#f0f0f5; }
.f-modal-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; }
.f-modal-close { background:none; border:none; color: rgba(255,255,255,0.4); font-size: 1.5rem; cursor:pointer; }

.fitness-app .set-row { display:grid; grid-template-columns: 2fr 1fr 1fr 1fr auto; gap:6px; align-items:end; margin-bottom:8px; }
@media (max-width: 560px) { .fitness-app .set-row { grid-template-columns: 1fr 1fr 1fr; } .fitness-app .set-row .exer-field { grid-column: 1 / -1; } .fitness-app .set-row .rm-set { grid-column: 3 / 4; justify-self:end; } }

.fitness-app .macro-grid { display:grid; grid-template-columns: repeat(2, 1fr); gap:10px; }
@media (min-width: 560px) { .fitness-app .macro-grid { grid-template-columns: repeat(4, 1fr); } }
.fitness-app .macro-ring { text-align:center; padding:10px; background: var(--surface-2); border:1px solid var(--border); border-radius:10px; }
.fitness-app .macro-ring canvas { max-width: 90px; margin: 0 auto; display:block; }
.fitness-app .macro-ring .lbl { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; margin-top: 4px; }
.fitness-app .macro-ring .val { font-size: 0.85rem; font-weight:600; margin-top:2px; }

.fitness-app .quick-foods { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
.fitness-app .quick-food { background: var(--surface-2); border: 1px solid var(--border); color: var(--text-mid); padding: 6px 10px; border-radius: 6px; font-size: 0.8rem; cursor: pointer; font-family: inherit; }
.fitness-app .quick-food:hover { border-color: var(--accent); color: var(--text); }

.fitness-app .food-results { position:absolute; top: 100%; left: 0; right: 0; background: #0a0a14; border: 1px solid var(--border-2); border-radius: 8px; margin-top: 4px; max-height: 420px; overflow-y: auto; z-index: 20; display: none; }
.fitness-app .food-results.open { display: block; }
.fitness-app .food-result { padding: 10px 12px; cursor: pointer; border-bottom: 1px solid var(--border); }
.fitness-app .food-result:hover, .fitness-app .food-result.active { background: var(--surface-3); }
.fitness-app .food-result .title { font-size: 0.9rem; color: var(--text); display: flex; gap: 6px; align-items: center; }
.fitness-app .food-result .sub { font-size: 0.75rem; color: var(--text-dim); margin-top: 2px; }
.fitness-app .food-result .macros { font-size: 0.7rem; color: var(--text-mid); margin-top: 3px; }
.fitness-app .source-badge { display: inline-block; padding: 1px 6px; border-radius: 4px; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; }
.fitness-app .source-badge.usda { background: rgba(96,165,250,0.15); color: var(--accent); }
.fitness-app .source-badge.openfoodfacts { background: rgba(52,211,153,0.15); color: var(--green); }
.fitness-app .source-badge.nutritionix, .fitness-app .source-badge.restaurant { background: rgba(251,191,36,0.15); color: var(--yellow); }
.fitness-app .source-badge.custom { background: rgba(167,139,250,0.15); color: var(--accent-2); }
.fitness-app .food-section-header { padding: 6px 12px; font-size: 0.65rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em; background: var(--surface-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

.fitness-app .food-selected { margin-top: 10px; padding: 10px; background: var(--surface-2); border: 1px solid var(--border-2); border-radius: 8px; }

.fitness-app .goto-meals { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; margin-bottom: 10px; }
.fitness-app .goto-meal { background: var(--surface-2); border: 1px solid var(--border); border-radius: 10px; padding: 10px; position: relative; }
.fitness-app .goto-meal h3 { margin: 0 0 4px; font-size: 0.95rem; font-weight: 600; }
.fitness-app .goto-meal .items { font-size: 0.75rem; color: var(--text-mid); line-height: 1.4; max-height: 60px; overflow: hidden; text-overflow: ellipsis; margin: 4px 0 8px; }
.fitness-app .goto-meal .macro-line { font-size: 0.75rem; color: var(--text-mid); margin-bottom: 8px; font-family: ui-monospace, monospace; }
.fitness-app .goto-meal .goto-actions { display: flex; gap: 6px; flex-wrap: wrap; }
.fitness-app .goto-meal-empty { color: var(--text-dim); font-size: 0.85rem; padding: 8px 0; grid-column: 1 / -1; }

.fitness-app .builder-items { display:flex; flex-direction:column; gap:6px; margin: 10px 0; }
.fitness-app .builder-item { display:flex; gap:8px; align-items:center; background: var(--surface-2); padding: 8px 10px; border-radius: 8px; font-size: 0.85rem; }
.fitness-app .builder-item .rm { background: none; border: none; color: var(--red); cursor: pointer; font-size: 1.1rem; }

.fitness-app .muted { color: var(--text-dim); font-size: 0.85rem; }
.fitness-app .disclaimer { font-size: 0.75rem; color: var(--text-dim); font-style: italic; padding: 8px 10px; background: rgba(251,191,36,0.05); border: 1px solid rgba(251,191,36,0.2); border-radius: 6px; margin-top: 8px; }
.fitness-app .loading { display:inline-block; width:14px; height:14px; border:2px solid var(--text-dim); border-top-color: var(--accent); border-radius:50%; animation: f-spin 0.8s linear infinite; vertical-align: middle; margin-right: 6px; }
@keyframes f-spin { to { transform: rotate(360deg); } }

.fitness-app .tag { display: inline-block; padding: 2px 6px; border-radius: 4px; font-size: 0.7rem; background: var(--surface-3); color: var(--text-mid); }
.fitness-app .tag.seed { background: rgba(96,165,250,0.15); color: var(--accent); }
</style>

<div class="ambient"></div>

<div class="fitness-app">
  <div class="f-hero">
    <h1><span class="f-logo">Fitness</span> Tracker</h1>
    <a href="/dashboard" class="back-link">← Dashboard</a>
  </div>

  <nav class="tabs">
    <ul role="tablist" aria-label="Fitness sections">
      <li role="presentation"><button class="tab-btn active" data-tab="dashboard" role="tab" aria-selected="true" aria-controls="panel-dashboard">Dashboard</button></li>
      <li role="presentation"><button class="tab-btn" data-tab="workouts" role="tab" aria-selected="false" aria-controls="panel-workouts">Workouts</button></li>
      <li role="presentation"><button class="tab-btn" data-tab="diet" role="tab" aria-selected="false" aria-controls="panel-diet">Diet</button></li>
      <li role="presentation"><button class="tab-btn" data-tab="photos" role="tab" aria-selected="false" aria-controls="panel-photos">Photos</button></li>
      <li role="presentation"><button class="tab-btn" data-tab="weight" role="tab" aria-selected="false" aria-controls="panel-weight">Bodyweight</button></li>
    </ul>
  </nav>
  <div id="f-error-banner" role="alert" style="display:none; background:rgba(248,113,113,0.12); border:1px solid rgba(248,113,113,0.4); color:#fca5a5; padding:10px 14px; border-radius:8px; margin:0 0 12px; font-size:0.9rem;"></div>

  <!-- ============ DASHBOARD ============ -->
  <section class="panel active" id="panel-dashboard">
    <div class="f-card">
      <h2>Today</h2>
      <div class="status-row" id="today-status">
        <div class="status-chip"><div class="lbl">Weight</div><div class="val" id="today-weight">—</div></div>
        <div class="status-chip"><div class="lbl">Workout</div><div class="val" id="today-workout">—</div></div>
        <div class="status-chip"><div class="lbl">Calories</div><div class="val" id="today-cals">—</div></div>
      </div>
    </div>
    <div class="grid-2">
      <div class="f-card">
        <h2>Bodyweight (last 90 days)</h2>
        <div class="chart-wrap"><canvas id="dash-weight-chart"></canvas></div>
      </div>
      <div class="f-card">
        <h2>Weekly Sets (last 8 weeks)</h2>
        <div class="chart-wrap"><canvas id="dash-volume-chart"></canvas></div>
      </div>
    </div>
    <div class="grid-2">
      <div class="f-card">
        <h2>7-day Macros (avg)</h2>
        <div id="dash-macros">—</div>
      </div>
      <div class="f-card">
        <h2>Latest Photo</h2>
        <div id="dash-photo">No photos yet.</div>
      </div>
    </div>
  </section>

  <!-- ============ WORKOUTS ============ -->
  <section class="panel" id="panel-workouts">
    <div class="f-card">
      <h2>Log Workout</h2>
      <div class="form-row">
        <div class="form-field" style="max-width:140px;">
          <label>Date</label>
          <input type="date" id="wo-date">
        </div>
        <div class="form-field">
          <label>Session Name</label>
          <select id="wo-name">
            <option>Push (Chest & Shoulders)</option>
            <option>Pull (Back & Calves)</option>
            <option>Legs</option>
            <option>Arms</option>
            <option>Upper Body</option>
            <option>Lower Body</option>
            <option>Full Body</option>
            <option value="__custom__">Custom…</option>
          </select>
        </div>
        <div class="form-field" style="max-width:110px;">
          <label>Duration (min)</label>
          <input type="number" id="wo-duration" inputmode="numeric" min="0" max="600">
        </div>
      </div>
      <div id="wo-custom-wrap" style="display:none;" class="form-row">
        <div class="form-field">
          <label>Custom Name</label>
          <input type="text" id="wo-custom-name">
        </div>
      </div>
      <div id="wo-sets-container"></div>
      <div class="form-row">
        <button class="f-btn secondary small" id="wo-add-set">+ Add Set</button>
        <button class="f-btn" id="wo-save">Save Session</button>
      </div>
      <div class="muted" id="wo-save-status"></div>
    </div>

    <div class="f-card">
      <h2>History</h2>
      <div class="history-list" id="wo-history"></div>
    </div>

    <div class="f-card">
      <h2>Exercise Tracker</h2>
      <div class="form-row">
        <div class="form-field">
          <label>Exercise</label>
          <input type="text" id="ex-search" list="exercises-list" placeholder="e.g. Smith Shoulder Press">
          <datalist id="exercises-list"></datalist>
        </div>
        <button class="f-btn secondary" id="ex-load">Load</button>
      </div>
      <div class="grid-2">
        <div class="chart-wrap"><canvas id="ex-weight-chart"></canvas></div>
        <div class="chart-wrap"><canvas id="ex-1rm-chart"></canvas></div>
      </div>
    </div>
  </section>

  <!-- ============ DIET ============ -->
  <section class="panel" id="panel-diet">
    <div class="f-card">
      <h2>Go-to Meals</h2>
      <div id="goto-meals-list" class="goto-meals"></div>
      <button class="f-btn secondary small" id="goto-new">+ Build New Go-to Meal</button>
    </div>

    <div class="f-card">
      <h2>Log Food</h2>
      <div class="form-row">
        <div class="form-field" style="max-width:140px;">
          <label>Date</label>
          <input type="date" id="diet-date">
        </div>
        <div class="form-field" style="max-width:140px;">
          <label>Meal</label>
          <select id="diet-meal">
            <option>Breakfast</option><option>Lunch</option><option>Dinner</option><option>Snack</option>
          </select>
        </div>
        <div class="form-field" style="position:relative;">
          <label>Search food</label>
          <input type="text" id="food-search" placeholder="e.g. chicken breast, oats, greek yogurt" autocomplete="off">
          <div id="food-search-results" class="food-results"></div>
        </div>
      </div>
      <div id="food-selected" class="food-selected" style="display:none;">
        <div class="form-row" style="align-items:center;">
          <div class="form-field" style="flex:2;"><label>Selected</label><div id="food-selected-name" class="f-card" style="margin:0; padding:8px 10px;"></div></div>
