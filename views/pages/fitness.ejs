<!-- Modal root -->
<div id="modal-root"></div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// ================== Utilities ==================
// Normalize a fetch Response. get() throws on failure (callers/tab-render catch it);
// post/postForm/del resolve to a {error} object so the existing `if (r.error)`
// branches fire instead of crashing on a JSON parse of a non-JSON error page.
async function readJsonSafe(r) { try { return await r.json(); } catch (_) { return null; } }
const api = {
  async get(path) { const r = await fetch(path, { credentials:'same-origin' }); if (!r.ok) { const d = await readJsonSafe(r); throw new Error((d && d.error) || ('HTTP ' + r.status)); } return r.json(); },
  async post(path, body) { const r = await fetch(path, { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)}); const d = await readJsonSafe(r); if (!r.ok) return { error: (d && d.error) || ('HTTP ' + r.status) }; return d || {}; },
  async postForm(path, formData) { const r = await fetch(path, { method:'POST', credentials:'same-origin', body: formData }); const d = await readJsonSafe(r); if (!r.ok) return { error: (d && d.error) || ('HTTP ' + r.status) }; return d || {}; },
  async del(path) { const r = await fetch(path, { method:'DELETE', credentials:'same-origin' }); const d = await readJsonSafe(r); if (!r.ok) return { error: (d && d.error) || ('HTTP ' + r.status) }; return d || {}; }
};
const today = () => { const d = new Date(); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; };
const addDays = (isoDate, n) => { const d = new Date(isoDate + 'T00:00:00'); d.setDate(d.getDate() + n); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; };
const fmtDate = (iso) => { if (!iso || typeof iso !== 'string') return '—'; const [y,m,d] = iso.split('-'); if (!y || !m || !d) return iso; return `${m}/${d}/${y.slice(2)}`; };

// Global error banner — surfaces failed loads instead of leaving a blank tab.
function showGlobalError(msg) {
  const el = document.getElementById('f-error-banner');
  if (!el) return;
  el.textContent = msg;
  el.style.display = 'block';
}
function clearGlobalError() {
  const el = document.getElementById('f-error-banner');
  if (el) el.style.display = 'none';
}

// Tab switching
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    const tab = btn.dataset.tab;
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.getElementById(`panel-${tab}`).classList.add('active');
    onTabActivate(tab);
  });
});

function onTabActivate(tab) {
  const fn = { dashboard: renderDashboard, workouts: renderWorkouts, diet: renderDiet, photos: renderPhotos, weight: renderWeightTab }[tab];
  if (!fn) return;
  clearGlobalError();
  Promise.resolve().then(fn).catch(err => {
    console.error('Failed to load tab:', tab, err);
    showGlobalError(`Couldn't load ${tab}: ${err && err.message ? err.message : err}`);
  });
}

// ================== Chart defaults ==================
Chart.defaults.color = 'rgba(255,255,255,0.65)';
Chart.defaults.borderColor = 'rgba(255,255,255,0.08)';
Chart.defaults.font.family = 'system-ui, -apple-system, sans-serif';
const chartRegistry = {};
function destroyChart(key) { if (chartRegistry[key]) { chartRegistry[key].destroy(); delete chartRegistry[key]; } }

// ================== Dashboard ==================
async function renderDashboard() {
  const t = today();
  // Fetch today's diet date-scoped: the un-dated endpoint is capped at 500 rows
  // DESC, so with a long history today's entries could fall off the Today stat.
  const [weights, workouts, dietAll, todayDiet] = await Promise.all([
    api.get('/api/fitness/weight'),
    api.get('/api/fitness/workouts'),
    api.get('/api/fitness/diet'),
    api.get('/api/fitness/diet?date=' + t)
  ]);
  const todayWeight = weights.find(w => w.date === t);
  const todayWorkouts = workouts.filter(w => w.date === t);
  const todayCals = todayDiet.reduce((s, d) => s + (d.calories || 0), 0);

  document.getElementById('today-weight').textContent = todayWeight ? `${todayWeight.weight_lbs} lbs` : '—';
  document.getElementById('today-weight').parentElement.className = 'status-chip ' + (todayWeight ? 'ok' : 'no');
  document.getElementById('today-workout').textContent = todayWorkouts.length ? `${todayWorkouts.length} session${todayWorkouts.length > 1 ? 's' : ''}` : '—';
  document.getElementById('today-workout').parentElement.className = 'status-chip ' + (todayWorkouts.length ? 'ok' : 'no');
  document.getElementById('today-cals').textContent = todayCals ? `${todayCals} kcal` : '—';
  document.getElementById('today-cals').parentElement.className = 'status-chip ' + (todayCals ? 'ok' : 'no');

  // 90-day weight chart
  const cutoff = addDays(t, -90);
  const recent = weights.filter(w => w.date >= cutoff).sort((a,b) => a.date.localeCompare(b.date));
  destroyChart('dash-weight');
  chartRegistry['dash-weight'] = new Chart(document.getElementById('dash-weight-chart'), {
    type: 'line',
    data: { labels: recent.map(r => r.date), datasets: [{ label:'Weight (lbs)', data: recent.map(r => r.weight_lbs), borderColor:'#60a5fa', backgroundColor:'rgba(96,165,250,0.15)', tension:0.3, pointRadius: 3, fill:true }]},
    options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false }}, scales:{ x:{ ticks:{ maxRotation:0, autoSkip:true, maxTicksLimit:6 }}}}
  });

  // 8-week volume chart
  const weeks = [];
  for (let i = 7; i >= 0; i--) weeks.push(addDays(t, -i * 7));
  const counts = weeks.map((w, i) => {
    const end = i === weeks.length - 1 ? t : addDays(weeks[i + 1], -1);
    const range = workouts.filter(s => s.date >= w && s.date <= end);
    return range.reduce((s, x) => s + (x.set_count || 0), 0);
  });
  destroyChart('dash-vol');
  chartRegistry['dash-vol'] = new Chart(document.getElementById('dash-volume-chart'), {
    type: 'bar',
    data: { labels: weeks.map(w => fmtDate(w)), datasets: [{ label:'Sets', data: counts, backgroundColor:'rgba(167,139,250,0.5)', borderColor:'#a78bfa', borderWidth:1 }]},
    options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false }}}
  });

  // 7-day macros
  const wkAgo = addDays(t, -7);
  const wkDiet = dietAll.filter(d => d.date >= wkAgo && d.date <= t);
  const avg = (key) => wkDiet.length ? Math.round((wkDiet.reduce((s, d) => s + (d[key] || 0), 0) / 7) * 10) / 10 : 0;
  const macrosEl = document.getElementById('dash-macros');
  if (!wkDiet.length) macrosEl.textContent = 'No diet entries in last 7 days.';
  else macrosEl.innerHTML = `
    <div class="status-row">
      <div class="status-chip"><div class="lbl">Cals/day</div><div class="val">${Math.round(wkDiet.reduce((s,d)=>s+(d.calories||0),0)/7)}</div></div>
      <div class="status-chip"><div class="lbl">Protein</div><div class="val">${avg('protein_g')}g</div></div>
      <div class="status-chip"><div class="lbl">Carbs</div><div class="val">${avg('carbs_g')}g</div></div>
      <div class="status-chip"><div class="lbl">Fat</div><div class="val">${avg('fat_g')}g</div></div>
    </div>`;

  // Latest photo
  const photos = await api.get('/api/fitness/photos');
  const photoEl = document.getElementById('dash-photo');
  if (!photos.length) { photoEl.textContent = 'No photos yet.'; return; }
  const fronts = photos.filter(p => p.angle === 'front');
  const latest = (fronts.length ? fronts : photos).reduce((a, b) => a.date > b.date ? a : b);
  photoEl.innerHTML = `
    <div style="display:flex; gap:12px; align-items:flex-start;">
      <img src="/api/fitness/photos/${latest.id}/image" style="width:100px; height:140px; object-fit:cover; border-radius:8px;" alt="Latest progress photo, ${fmtDate(latest.date)}">
      <div>
        <div style="font-weight:600; margin-bottom:4px;">${fmtDate(latest.date)}</div>
        <div class="muted">${escapeHtml(latest.angle) || '—'}${latest.weight_lbs ? ' • ' + latest.weight_lbs + ' lbs' : ''}</div>
        ${latest.bf_estimate_pct ? `<div class="muted">BF ~${latest.bf_estimate_pct}%</div>` : '<div class="muted">No AI analysis yet</div>'}
      </div>
    </div>`;
}

// ================== Workouts ==================
let allExercises = [];
function buildSetRow() {
  const div = document.createElement('div');
  div.className = 'set-row';
  div.innerHTML = `
    <div class="form-field exer-field"><label>Exercise</label><input type="text" list="exercises-list" class="set-exer"></div>
    <div class="form-field"><label>Weight</label><input type="number" inputmode="decimal" class="set-weight" step="0.5"></div>
    <div class="form-field"><label>Reps</label><input type="number" inputmode="numeric" class="set-reps"></div>
    <div class="form-field"><label>RPE</label><input type="number" inputmode="decimal" class="set-rpe" min="1" max="10" step="0.5"></div>
    <button class="f-btn secondary small rm-set" type="button">×</button>
  `;
  div.querySelector('.rm-set').addEventListener('click', () => div.remove());
  return div;
}

async function renderWorkouts() {
  if (!document.getElementById('wo-date').value) document.getElementById('wo-date').value = today();
  const container = document.getElementById('wo-sets-container');
  if (!container.children.length) { container.appendChild(buildSetRow()); container.appendChild(buildSetRow()); }

  allExercises = await api.get('/api/fitness/exercises');
  const dl = document.getElementById('exercises-list');
  dl.innerHTML = allExercises.map(e => `<option value="${escapeHtml(e)}">`).join('');

  const workouts = await api.get('/api/fitness/workouts');
  const list = document.getElementById('wo-history');
  list.innerHTML = workouts.slice(0, 100).map(w => `
    <div class="hist-item" data-id="${w.id}">
      <div class="hist-head">
        <div>
          <div class="hist-date">${fmtDate(w.date)} <span class="tag ${w.seed_origin ? 'seed' : ''}">${w.seed_origin ? 'imported' : 'logged'}</span></div>
          <div class="hist-meta">${w.name || 'Workout'} • ${w.set_count} sets${w.duration_min ? ' • ' + w.duration_min + ' min' : ''}</div>
        </div>
        <button class="f-btn danger small" data-del="${w.id}">Delete</button>
      </div>
      <div class="hist-sets" id="sets-${w.id}"></div>
    </div>
  `).join('');

  list.querySelectorAll('.hist-item').forEach(item => {
    item.addEventListener('click', async (e) => {
      if (e.target.closest('[data-del]')) return;
      const id = item.dataset.id;
      if (item.classList.contains('expanded')) { item.classList.remove('expanded'); return; }
      const target = document.getElementById('sets-' + id);
      if (!target.innerHTML) {
        const data = await api.get('/api/fitness/workouts/' + id);
        target.innerHTML = renderSetsTable(data.sets);
      }
      item.classList.add('expanded');
    });
  });
  list.querySelectorAll('[data-del]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      if (!confirm('Delete this workout session and all its sets?')) return;
      await api.del('/api/fitness/workouts/' + btn.dataset.del);
      renderWorkouts();
    });
  });
}

function renderSetsTable(sets) {
  if (!sets || !sets.length) return '<div class="muted">No sets.</div>';
  // Compute PRs per exercise (highest weight × reps)
  const exBest = {};
  sets.forEach(s => {
    if (s.weight_lbs == null || s.reps == null) return;
    const prod = s.weight_lbs * s.reps;
    if (!exBest[s.exercise] || prod > exBest[s.exercise].prod) exBest[s.exercise] = { prod, id: s.id };
  });
  return `<div class="table-wrap"><table><thead><tr><th>Exercise</th><th>Set</th><th>Weight</th><th>Reps</th><th>RPE</th><th>Notes</th></tr></thead><tbody>${
    sets.map(s => `<tr>
      <td>${escapeHtml(s.exercise)}${exBest[s.exercise] && exBest[s.exercise].id === s.id ? ' <span class="pr-badge">🏆</span>' : ''}</td>
      <td>${s.set_number ?? ''}</td>
      <td>${s.weight_lbs ?? ''}</td>
      <td>${s.reps ?? ''}</td>
      <td>${s.rpe ?? ''}</td>
      <td class="muted">${escapeHtml(s.notes || '')}</td>
    </tr>`).join('')
  }</tbody></table></div>`;
}

document.getElementById('wo-name').addEventListener('change', (e) => {
  document.getElementById('wo-custom-wrap').style.display = e.target.value === '__custom__' ? 'flex' : 'none';
});
document.getElementById('wo-add-set').addEventListener('click', (e) => {
  e.preventDefault();
  document.getElementById('wo-sets-container').appendChild(buildSetRow());
});
document.getElementById('wo-save').addEventListener('click', async (e) => {
  e.preventDefault();
  const btn = e.currentTarget;
  if (btn.disabled) return;            // guard against double-submit
  const status = document.getElementById('wo-save-status');
  btn.disabled = true;
  status.innerHTML = '<span class="loading"></span>Saving…';
  try {
    const date = document.getElementById('wo-date').value;
    const nameVal = document.getElementById('wo-name').value;
    const name = nameVal === '__custom__' ? document.getElementById('wo-custom-name').value || 'Custom' : nameVal;
    const duration_min = parseInt(document.getElementById('wo-duration').value, 10) || null;
    const { id: sessionId, error } = await api.post('/api/fitness/workouts', { date, name, duration_min });
    if (error) { status.textContent = 'Error: ' + error; return; }
    const rows = [...document.querySelectorAll('#wo-sets-container .set-row')];
    let setCounter = {};
    for (const row of rows) {
      const exercise = row.querySelector('.set-exer').value.trim();
      const weight_lbs = parseFloat(row.querySelector('.set-weight').value);
      const reps = parseInt(row.querySelector('.set-reps').value, 10);
      const rpe = parseFloat(row.querySelector('.set-rpe').value);
      if (!exercise) continue;
      setCounter[exercise] = (setCounter[exercise] || 0) + 1;
      const sr = await api.post(`/api/fitness/workouts/${sessionId}/sets`, { exercise, set_number: setCounter[exercise], weight_lbs: isNaN(weight_lbs)?null:weight_lbs, reps: isNaN(reps)?null:reps, rpe: isNaN(rpe)?null:rpe });
      if (sr.error) { status.textContent = 'Error saving set: ' + sr.error; return; }
    }
    status.textContent = 'Saved ✓';
    document.getElementById('wo-sets-container').innerHTML = '';
    document.getElementById('wo-sets-container').appendChild(buildSetRow());
    document.getElementById('wo-sets-container').appendChild(buildSetRow());
    setTimeout(() => status.textContent = '', 2500);
    await renderWorkouts();
  } catch (err) {
    status.textContent = 'Error: ' + (err && err.message ? err.message : err);
  } finally {
    btn.disabled = false;
  }
});

document.getElementById('ex-load').addEventListener('click', async (e) => {
  e.preventDefault();
  const name = document.getElementById('ex-search').value.trim();
  if (!name) return;
  let rows;
  try {
    rows = await api.get('/api/fitness/exercises/' + encodeURIComponent(name));
  } catch (err) { alert('Failed to load exercise: ' + (err && err.message ? err.message : err)); return; }
  if (!rows.length) { alert('No data for that exercise.'); return; }
  // Aggregate by date — take top set per date
  const byDate = {};
  rows.forEach(r => {
    if (r.weight_lbs == null || r.reps == null) return;
    if (!byDate[r.date] || r.weight_lbs > byDate[r.date].weight) byDate[r.date] = { weight: r.weight_lbs, reps: r.reps };
  });
  const dates = Object.keys(byDate).sort();
  const weights = dates.map(d => byDate[d].weight);
  const oneRM = dates.map(d => { const s = byDate[d]; return +(s.weight * (1 + s.reps / 30)).toFixed(1); });
  destroyChart('ex-w'); destroyChart('ex-rm');
  chartRegistry['ex-w'] = new Chart(document.getElementById('ex-weight-chart'), {
    type:'line', data:{ labels: dates, datasets:[{ label:'Top weight (lbs)', data: weights, borderColor:'#60a5fa', backgroundColor:'rgba(96,165,250,0.15)', tension:0.3, fill:true }]},
    options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false }, title:{ display:true, text:'Top weight per session' }}, scales:{ x:{ ticks:{ maxTicksLimit:6 }}}}
  });
  chartRegistry['ex-rm'] = new Chart(document.getElementById('ex-1rm-chart'), {
    type:'line', data:{ labels: dates, datasets:[{ label:'Estimated 1RM', data: oneRM, borderColor:'#34d399', backgroundColor:'rgba(52,211,153,0.15)', tension:0.3, fill:true }]},
    options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false }, title:{ display:true, text:'Estimated 1RM (Epley)' }}, scales:{ x:{ ticks:{ maxTicksLimit:6 }}}}
  });
});

// ================== Diet ==================
// Default targets tuned for "maintain muscle while trimming fat, protein surplus"
// ~1g/lb bodyweight protein at ~170 lbs → 200P, moderate cut: 2500 kcal
const DEFAULT_TARGETS = { calories: 2500, protein_g: 200, carbs_g: 260, fat_g: 75 };
function getDietTargets() {
  try {
    const v = JSON.parse(localStorage.getItem('fitness.diet.targets'));
    return (v && typeof v === 'object' && !Array.isArray(v)) ? { ...DEFAULT_TARGETS, ...v } : { ...DEFAULT_TARGETS };
  } catch { return { ...DEFAULT_TARGETS }; }
}
function setDietTargets(t) { localStorage.setItem('fitness.diet.targets', JSON.stringify(t)); }

function renderMacroRing(canvas, value, target, label, color) {
  const pct = target > 0 ? Math.max(0, Math.min(120, (value / target) * 100)) : 0;
  const ctx = canvas.getContext('2d');
  canvas.width = 80; canvas.height = 80;
  ctx.clearRect(0,0,80,80);
  ctx.strokeStyle = 'rgba(255,255,255,0.1)'; ctx.lineWidth = 8;
  ctx.beginPath(); ctx.arc(40,40,32,0,Math.PI*2); ctx.stroke();
  ctx.strokeStyle = color; ctx.lineWidth = 8; ctx.lineCap = 'round';
  ctx.beginPath(); ctx.arc(40,40,32, -Math.PI/2, -Math.PI/2 + (Math.min(pct,100)/100)*Math.PI*2); ctx.stroke();
  ctx.fillStyle = '#f0f0f5'; ctx.font = 'bold 13px system-ui'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText(Math.round(pct) + '%', 40, 40);
}

