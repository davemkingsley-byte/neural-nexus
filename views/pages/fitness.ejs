// ================== Photos ==================
let lastSessions = [];        // cache so trend toggles don't re-fetch
let compareMode = false;      // photo-compare selection mode
let comparePicks = [];
async function renderPhotos() {
  if (!document.getElementById('photo-date').value) document.getElementById('photo-date').value = today();
  // Show active vision provider (anthropic / ollama + model)
  try {
    const info = await api.get('/api/fitness/vision-provider');
    const el = document.getElementById('vision-provider-info');
    if (el) {
      const label = info.provider === 'ollama'
        ? `🖥️ Local vision: <code style="background:var(--surface-3); padding:1px 6px; border-radius:3px;">${escapeHtml(info.model || 'ollama')}</code>`
        : `☁️ Cloud vision: <code style="background:var(--surface-3); padding:1px 6px; border-radius:3px;">${escapeHtml(info.model || 'anthropic')}</code>`;
      el.innerHTML = label + (info.configured ? '' : ' <span style="color:var(--red);">(not configured)</span>');
    }
  } catch (_) {}
  const sessions = await api.get('/api/fitness/sessions');
  lastSessions = sessions;
  const totalPhotos = sessions.reduce((a, s) => a + s.photos.length, 0);
  document.getElementById('photo-count').textContent = `— ${sessions.length} sessions, ${totalPhotos} photos`;

  // Render session cards (newest first)
  const listEl = document.getElementById('sessions-list');
  listEl.innerHTML = [...sessions].reverse().map(s => {
    let assessment = '';
    if (s.ai_analysis) {
      try {
        const a = JSON.parse(s.ai_analysis);
        if (a.assessment) assessment = `<div class="session-assessment">${escapeHtml(a.assessment)}</div>`;
      } catch (_) {}
    }
    const stats = [];
    if (s.weight_lbs) stats.push(`<span>⚖️ ${s.weight_lbs} lbs</span>`);
    if (s.bf_estimate_pct != null) stats.push(`<span>BF ${s.bf_estimate_pct}%</span>`);
    if (s.lbm_estimate_lbs != null) stats.push(`<span>LBM ${s.lbm_estimate_lbs}</span>`);
    if (s.ffmi_estimate != null) stats.push(`<span>FFMI ${s.ffmi_estimate}</span>`);
    const sortedAngles = [...s.photos].sort((a, b) => {
      const order = { front: 0, back: 1, left: 2, right: 3 };
      return (order[a.angle] ?? 99) - (order[b.angle] ?? 99);
    });
    return `
      <div class="session-card" data-date="${s.date}">
        <div class="head">
          <div>
            <div class="session-date">${fmtDate(s.date)}</div>
            <div class="session-stats">${stats.join('') || '<span class="muted">no analysis yet</span>'}</div>
          </div>
          <div style="display:flex; gap:6px;">
            <button class="f-btn secondary small" data-session-analyze="${s.date}">${s.ai_analysis ? '↻ Re-analyze' : '🔬 Analyze'}</button>
            <button class="f-btn danger small" data-session-del="${s.date}">×</button>
          </div>
        </div>
        <div class="session-angles">
          ${sortedAngles.map(p => `
            <div class="session-angle" data-photo-id="${p.id}">
              <img src="/api/fitness/photos/${p.id}/image" loading="lazy" alt="${escapeHtml(p.angle || 'progress')} photo, ${fmtDate(s.date)}">
              <div class="label">${escapeHtml(p.angle || '')}</div>
            </div>
          `).join('')}
        </div>
        ${assessment}
      </div>
    `;
  }).join('');

  // Wire card interactions
  listEl.querySelectorAll('[data-session-analyze]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const date = btn.dataset.sessionAnalyze;
      btn.disabled = true;
      const prev = btn.textContent;
      btn.innerHTML = '<span class="loading"></span>Analyzing…';
      const r = await api.post(`/api/fitness/photos/session/${date}/analyze`, {});
      btn.disabled = false;
      btn.textContent = prev;
      if (r.error) { alert(r.error); return; }
      renderPhotos();
    });
  });
  listEl.querySelectorAll('[data-session-del]').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm(`Delete all ${btn.dataset.sessionDel} photos?`)) return;
      const date = btn.dataset.sessionDel;
      const session = sessions.find(s => s.date === date);
      if (!session) return;
      for (const p of session.photos) await api.del('/api/fitness/photos/' + p.id);
      renderPhotos();
    });
  });
  listEl.querySelectorAll('.session-angle').forEach(el => {
    el.addEventListener('click', () => {
      const id = +el.dataset.photoId;
      if (compareMode) toggleComparePick(id, el);
      else showPhotoModal(id);
    });
  });

  renderBodyCompTrend(sessions);

  // Show "analyze all unanalyzed" if any sessions lack analysis
  const unanalyzed = sessions.filter(s => !s.ai_analysis);
  const btn = document.getElementById('photo-analyze-all');
  btn.style.display = unanalyzed.length ? 'inline-block' : 'none';
  btn.textContent = `Analyze All ${unanalyzed.length} Unanalyzed Sessions`;
}

// Smoothed rolling average. window = 3 sessions (configurable).
function rollingAverage(values, windowSize) {
  const out = [];
  for (let i = 0; i < values.length; i++) {
    const slice = values.slice(Math.max(0, i - windowSize + 1), i + 1).filter(v => v != null);
    out.push(slice.length ? slice.reduce((a, b) => a + b, 0) / slice.length : null);
  }
  return out;
}

function renderBodyCompTrend(sessions) {
  destroyChart('bf');
  const withData = sessions.filter(s => s.bf_estimate_pct != null || s.lbm_estimate_lbs != null || s.ffmi_estimate != null);
  const emptyEl = document.getElementById('trend-empty');
  if (!withData.length) {
    if (emptyEl) emptyEl.style.display = 'block';
    return;
  }
  if (emptyEl) emptyEl.style.display = 'none';

  const labels = withData.map(s => s.date);
  const bf = withData.map(s => s.bf_estimate_pct);
  const lbm = withData.map(s => s.lbm_estimate_lbs);
  const ffmi = withData.map(s => s.ffmi_estimate);

  const showBF = document.getElementById('trend-show-bf').checked;
  const showLBM = document.getElementById('trend-show-lbm').checked;
  const showFFMI = document.getElementById('trend-show-ffmi').checked;
  const showSmooth = document.getElementById('trend-show-smooth').checked;

  const datasets = [];
  if (showBF) {
    datasets.push({ label: 'BF % (raw)', yAxisID: 'yPct', data: bf, borderColor: '#a78bfa', backgroundColor: '#a78bfa', showLine: false, pointRadius: 4, pointStyle: 'circle' });
    if (showSmooth) {
      datasets.push({ label: 'BF % (smoothed)', yAxisID: 'yPct', data: rollingAverage(bf, 3), borderColor: '#a78bfa', backgroundColor: 'rgba(167,139,250,0.1)', borderWidth: 2, tension: 0.35, fill: false, pointRadius: 0 });
    }
  }
  if (showLBM) {
    datasets.push({ label: 'LBM (lbs, raw)', yAxisID: 'yLbs', data: lbm, borderColor: '#34d399', backgroundColor: '#34d399', showLine: false, pointRadius: 4, pointStyle: 'triangle' });
    if (showSmooth) {
      datasets.push({ label: 'LBM (smoothed)', yAxisID: 'yLbs', data: rollingAverage(lbm, 3), borderColor: '#34d399', backgroundColor: 'rgba(52,211,153,0.1)', borderWidth: 2, tension: 0.35, fill: false, pointRadius: 0, borderDash: [4, 4] });
    }
  }
  if (showFFMI) {
    datasets.push({ label: 'FFMI (raw)', yAxisID: 'yFFMI', data: ffmi, borderColor: '#fbbf24', backgroundColor: '#fbbf24', showLine: false, pointRadius: 4, pointStyle: 'rect' });
    if (showSmooth) {
      datasets.push({ label: 'FFMI (smoothed)', yAxisID: 'yFFMI', data: rollingAverage(ffmi, 3), borderColor: '#fbbf24', backgroundColor: 'rgba(251,191,36,0.1)', borderWidth: 2, tension: 0.35, fill: false, pointRadius: 0, borderDash: [2, 6] });
    }
  }

  const scales = {
    x: { ticks: { maxTicksLimit: 8 }, grid: { color: 'rgba(255,255,255,0.04)' } }
  };
  if (showBF) scales.yPct = { position: 'left', title: { display: true, text: 'BF %' }, grid: { color: 'rgba(255,255,255,0.04)' } };
  if (showLBM) scales.yLbs = { position: showBF ? 'right' : 'left', title: { display: true, text: 'LBM (lbs)' }, grid: { drawOnChartArea: false } };
  if (showFFMI) scales.yFFMI = { position: 'right', title: { display: true, text: 'FFMI' }, grid: { drawOnChartArea: false } };

  chartRegistry['bf'] = new Chart(document.getElementById('bf-trend-chart'), {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 10 } } },
      scales
    }
  });
}

['trend-show-bf','trend-show-lbm','trend-show-ffmi','trend-show-smooth'].forEach(id => {
  document.getElementById(id).addEventListener('change', () => {
    // Reuse the already-loaded sessions — a checkbox toggle is a pure re-render.
    renderBodyCompTrend(lastSessions);
  });
});

document.getElementById('photo-upload').addEventListener('click', async (e) => {
  e.preventDefault();
  const btn = e.currentTarget;
  if (btn.disabled) return;
  const file = document.getElementById('photo-file').files[0];
  if (!file) { alert('Choose a photo.'); return; }
  const form = new FormData();
  form.append('photo', file);
  const date = document.getElementById('photo-date').value || today();
  form.append('date', date);
  form.append('angle', document.getElementById('photo-angle').value);
  const w = document.getElementById('photo-weight').value;
  if (w) form.append('weight_lbs', w);
  const result = document.getElementById('photo-result');
  btn.disabled = true;
  result.innerHTML = '<span class="loading"></span>Uploading…';
  try {
    const r = await api.postForm('/api/fitness/photos', form);
    if (r.error) { result.textContent = 'Error: ' + r.error; return; }
    document.getElementById('photo-file').value = '';
    if (r.analyzing) {
      // Analysis runs server-side in the background so the upload didn't block.
      result.innerHTML = 'Uploaded ✓ — running AI analysis in the background. The session card updates when it\'s ready.';
      await renderPhotos();
      pollSessionAnalysis(date);
    } else if (r.analysis) {
      result.innerHTML = `<strong>Done.</strong> BF ~${r.analysis.bf_pct}%, LBM ${r.analysis.lbm_lbs} lbs, FFMI ${r.analysis.ffmi}. <div class="muted" style="margin-top:6px;">${escapeHtml(r.analysis.assessment || '')}</div>`;
      await renderPhotos();
    } else {
      result.innerHTML = `Uploaded. <span class="muted">${escapeHtml(r.warning || '')}</span>`;
      await renderPhotos();
    }
  } catch (err) {
    result.textContent = 'Error: ' + (err && err.message ? err.message : err);
  } finally {
    btn.disabled = false;
  }
});

// Best-effort poll for background analysis to land, then refresh the session cards.
function pollSessionAnalysis(date, tries = 0) {
  if (tries >= 12) return; // ~60s; slow local models finish later — user can refresh
  setTimeout(async () => {
    try {
      const sessions = await api.get('/api/fitness/sessions');
      const s = sessions.find(x => x.date === date);
      if (s && s.ai_analysis) { await renderPhotos(); return; }
    } catch (_) {}
    pollSessionAnalysis(date, tries + 1);
  }, 5000);
}

document.getElementById('photo-analyze-all').addEventListener('click', async () => {
  const btn = document.getElementById('photo-analyze-all');
  const statusEl = document.getElementById('analyze-status');
  const sessions = await api.get('/api/fitness/sessions');
  const todo = sessions.filter(s => !s.ai_analysis);
  btn.disabled = true;
  for (let i = 0; i < todo.length; i++) {
    btn.textContent = `Analyzing ${i+1}/${todo.length}…`;
    statusEl.textContent = `Session ${todo[i].date} (${i+1}/${todo.length})`;
    const r = await api.post(`/api/fitness/photos/session/${todo[i].date}/analyze`, {});
    if (r.error) { alert('Stopped at ' + todo[i].date + ': ' + r.error); break; }
  }
  btn.disabled = false;
  statusEl.textContent = '';
  renderPhotos();
});

async function showPhotoModal(id) {
  const [photos, sessions] = await Promise.all([
    api.get('/api/fitness/photos'),
    api.get('/api/fitness/sessions')
  ]);
  const p = photos.find(x => x.id === id);
  if (!p) return;
  const same = photos.filter(x => x.date === p.date);
  // Pull the canonical analysis (incl. the assessment text) from the session row
  // for this date — /api/fitness/photos doesn't carry the ai_analysis JSON.
  const session = sessions.find(s => s.date === p.date);
  const hasAnalysis = !!(session && session.ai_analysis);
  let analysisHtml = '';
  if (hasAnalysis) {
    let assessment = '';
    try { const a = JSON.parse(session.ai_analysis); if (a.assessment) assessment = `<div class="muted" style="margin-top:6px;">${escapeHtml(a.assessment)}</div>`; } catch (_) {}
    const bits = [];
    if (session.bf_estimate_pct != null) bits.push(`BF ~${session.bf_estimate_pct}%`);
    if (session.lbm_estimate_lbs != null) bits.push(`LBM ${session.lbm_estimate_lbs} lbs`);
    if (session.ffmi_estimate != null) bits.push(`FFMI ${session.ffmi_estimate}`);
    analysisHtml = `<div class="f-card"><h3>AI Analysis</h3><div>${bits.join(' • ') || '—'}</div>${assessment}</div>`;
  }
  const body = `
    <div class="f-modal-head">
      <h2>${fmtDate(p.date)}${p.weight_lbs ? ' • ' + p.weight_lbs + ' lbs' : ''}</h2>
      <button class="f-modal-close">×</button>
    </div>
    <div class="photo-grid" style="grid-template-columns: repeat(${same.length}, 1fr);">
      ${same.map(x => `<div><img src="/api/fitness/photos/${x.id}/image" style="width:100%; border-radius:8px;" alt="${escapeHtml(x.angle || 'progress')} photo, ${fmtDate(x.date)}"><div class="muted" style="text-align:center; margin-top:4px;">${escapeHtml(x.angle || '')}</div></div>`).join('')}
    </div>
    ${analysisHtml}
    <div style="margin-top:12px; display:flex; gap:8px; flex-wrap:wrap;">
      ${!hasAnalysis ? '<button class="f-btn secondary" id="modal-analyze">Run AI Analysis</button>' : ''}
      <button class="f-btn danger" id="modal-delete">Delete This Photo</button>
    </div>
  `;
  openModal(body);
  document.getElementById('modal-delete').addEventListener('click', async () => {
    if (!confirm('Delete this photo?')) return;
    await api.del('/api/fitness/photos/' + id);
    closeModal();
    renderPhotos();
  });
  const aBtn = document.getElementById('modal-analyze');
  if (aBtn) aBtn.addEventListener('click', async () => {
    aBtn.innerHTML = '<span class="loading"></span>Analyzing…';
    const r = await api.post(`/api/fitness/photos/${id}/analyze`, {});
    if (r.error) { alert(r.error); aBtn.textContent = 'Run AI Analysis'; return; }
    closeModal(); renderPhotos();
  });
}

// ---- Photo compare ----
function setCompareMode(on) {
  compareMode = on;
  comparePicks = [];
  document.querySelectorAll('.session-angle.compare-pick').forEach(el => el.classList.remove('compare-pick'));
  const btn = document.getElementById('photo-compare-toggle');
  if (btn) btn.textContent = on ? '✕ Cancel compare' : '⇄ Compare';
  const status = document.getElementById('analyze-status');
  if (status) status.textContent = on ? 'Pick two photos to compare.' : '';
}
function toggleComparePick(id, el) {
  const idx = comparePicks.indexOf(id);
  if (idx >= 0) { comparePicks.splice(idx, 1); el.classList.remove('compare-pick'); }
  else {
    if (comparePicks.length >= 2) return;
    comparePicks.push(id); el.classList.add('compare-pick');
  }
  if (comparePicks.length === 2) {
    const ids = [...comparePicks];
    setCompareMode(false);
    showCompareModal(ids);
  }
}
document.getElementById('photo-compare-toggle').addEventListener('click', () => setCompareMode(!compareMode));

async function showCompareModal(ids) {
  const photos = await api.get('/api/fitness/photos');
  const a = photos.find(p => p.id === ids[0]);
  const b = photos.find(p => p.id === ids[1]);
  if (!a || !b) return;
  openModal(`
    <div class="f-modal-head"><h2>Compare</h2><button class="f-modal-close">×</button></div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
      <div><img src="/api/fitness/photos/${a.id}/image" style="width:100%; border-radius:8px;" alt="Progress photo, ${fmtDate(a.date)}"><div style="text-align:center; margin-top:6px;"><strong>${fmtDate(a.date)}</strong><br>${a.weight_lbs ? a.weight_lbs + ' lbs' : ''} ${a.bf_estimate_pct ? ' • BF ' + a.bf_estimate_pct + '%' : ''}</div></div>
      <div><img src="/api/fitness/photos/${b.id}/image" style="width:100%; border-radius:8px;" alt="Progress photo, ${fmtDate(b.date)}"><div style="text-align:center; margin-top:6px;"><strong>${fmtDate(b.date)}</strong><br>${b.weight_lbs ? b.weight_lbs + ' lbs' : ''} ${b.bf_estimate_pct ? ' • BF ' + b.bf_estimate_pct + '%' : ''}</div></div>
    </div>
  `);
}

let _modalKeyHandler = null;
let _modalPrevFocus = null;
function openModal(html) {
  const root = document.getElementById('modal-root');
  _modalPrevFocus = document.activeElement;
  root.innerHTML = `<div class="f-modal" id="modal-el"><div class="f-modal-content" role="dialog" aria-modal="true">${html}</div></div>`;
  const closeBtn = root.querySelector('.f-modal-close');
  if (closeBtn) { closeBtn.setAttribute('aria-label', 'Close'); closeBtn.addEventListener('click', closeModal); closeBtn.focus(); }
  root.querySelector('.f-modal').addEventListener('click', (e) => { if (e.target.id === 'modal-el') closeModal(); });
  _modalKeyHandler = (e) => { if (e.key === 'Escape') closeModal(); };
  document.addEventListener('keydown', _modalKeyHandler);
}
function closeModal() {
  document.getElementById('modal-root').innerHTML = '';
  if (_modalKeyHandler) { document.removeEventListener('keydown', _modalKeyHandler); _modalKeyHandler = null; }
  if (_modalPrevFocus && _modalPrevFocus.focus) { try { _modalPrevFocus.focus(); } catch (_) {} _modalPrevFocus = null; }
}

// ================== Bodyweight ==================
async function renderWeightTab() {
  if (!document.getElementById('bw-date').value) document.getElementById('bw-date').value = today();
  const rows = await api.get('/api/fitness/weight');
  destroyChart('bw');
  if (rows.length) {
    const sorted = [...rows].sort((a,b) => a.date.localeCompare(b.date));
    chartRegistry['bw'] = new Chart(document.getElementById('bw-trend-chart'), {
      type:'line', data:{ labels: sorted.map(r => r.date), datasets:[{ label:'Weight (lbs)', data: sorted.map(r => r.weight_lbs), borderColor:'#60a5fa', backgroundColor:'rgba(96,165,250,0.15)', tension:0.3, fill:true, pointRadius: 2 }]},
      options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false }}, scales:{ x:{ ticks:{ maxTicksLimit:8 }}}}
    });
  }
  const tbody = document.getElementById('bw-table');
  const sortedDesc = [...rows].sort((a,b) => b.date.localeCompare(a.date));
  tbody.innerHTML = sortedDesc.map(r => `
    <tr><td>${fmtDate(r.date)}</td><td>${r.weight_lbs} lbs</td><td class="muted">${escapeHtml(r.notes || '')}</td><td><button class="f-btn danger small" data-bw-del="${r.id}">×</button></td></tr>
  `).join('');
  tbody.querySelectorAll('[data-bw-del]').forEach(b => b.addEventListener('click', async () => {
    if (!confirm('Delete this entry?')) return;
    await api.del('/api/fitness/weight/' + b.dataset.bwDel);
    renderWeightTab();
  }));
}

document.getElementById('bw-add').addEventListener('click', async (e) => {
  e.preventDefault();
  const btn = e.currentTarget;
  if (btn.disabled) return;
  const date = document.getElementById('bw-date').value || today();
  const weight_lbs = parseFloat(document.getElementById('bw-weight').value);
  if (isNaN(weight_lbs)) { alert('Enter a weight.'); return; }
  const notes = document.getElementById('bw-notes').value.trim() || null;
  btn.disabled = true;
  try {
    const r = await api.post('/api/fitness/weight', { date, weight_lbs, notes });
    if (r.error) { alert(r.error); return; }
    document.getElementById('bw-weight').value = '';
    document.getElementById('bw-notes').value = '';
    await renderWeightTab();
  } finally {
    btn.disabled = false;
  }
});

// ================== Utilities ==================
function escapeHtml(s) { if (s == null) return ''; return String(s).replace(/[&<>"']/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c])); }

// Initial load (routed through onTabActivate so failures surface in the banner)
onTabActivate('dashboard');
</script>
