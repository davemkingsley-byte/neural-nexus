<!-- Hero -->
<section class="hero">
  <div class="hero-badge"><span class="pulse"></span> Read by 1,000+ subscribers</div>
  <h1>Where <span class="highlight">science</span> meets<br>the <span class="highlight">future</span></h1>
  <p class="hero-sub">Weekly deep dives on biotech, AI, and the science of what comes next — by a PhD scientist who works at the frontier.</p>
  <div class="hero-actions">
    <a href="#subscribe" class="btn-primary">Subscribe — it's free →</a>
    <a href="#games" class="btn-secondary">🎮 Play Daily Games</a>
  </div>
  <div class="scroll-hint"><span></span></div>
</section>

<!-- Articles -->
<section class="section-wrap" id="articles">
  <div class="section-label">Latest</div>
  <h2 class="section-title">Recent deep dives</h2>
  <div class="article-grid">
    <% (locals.featuredArticles || []).forEach(function(article) { %>
    <a href="<%= article.url %>" target="_blank" class="article-card">
      <div class="article-meta">
        <div class="article-date"><%= new Date(article.date + 'T12:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
        <h3><%= article.title %></h3>
        <p class="desc"><%= article.description %></p>
        <div class="article-cta">Read →</div>
      </div>
      <% if (article.thumbnail) { %>
      <img class="article-thumb" src="<%= article.thumbnail %>" alt="<%= article.title %>" loading="lazy" width="720" height="405">
      <% } %>
    </a>
    <% }); %>
  </div>
  <div class="archive-link">
    <a href="/archive">Explore the on-site archive →</a>
    <a href="https://blog.neuralnexus.press/archive" target="_blank" rel="noopener noreferrer">View the full Substack archive →</a>
  </div>
</section>

<!-- About -->
