<script>
(function() {
  var btn = document.getElementById('subscribe-btn');
  var input = document.getElementById('email-input');
  var status = document.getElementById('subscribe-status');
  function go() {
    var email = input.value.trim();
    var url = email
      ? 'https://blog.neuralnexus.press/subscribe?utm_source=neuralnexus&utm_medium=cta&utm_campaign=home-subscribe&email=' + encodeURIComponent(email)
      : 'https://blog.neuralnexus.press/subscribe?utm_source=neuralnexus&utm_medium=cta&utm_campaign=home-subscribe';
    if (status) { status.textContent = 'Redirecting to Substack…'; status.classList.add('visible'); }
    setTimeout(function() { window.open(url, '_blank', 'noopener'); }, 350);
  }
  btn.addEventListener('click', go);
  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') go(); });
})();

// Scroll-reveal: only hide elements that are NOT already in the viewport on load,
// so content above the fold appears instantly.
window.addEventListener('load', function() {
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -20px 0px' });
  var nodes = document.querySelectorAll('.card, .about-card, .game-card, .article-card');
  nodes.forEach(function(el) {
    var rect = el.getBoundingClientRect();
    if (rect.top > window.innerHeight) {
      el.classList.add('animate-on-scroll');
      observer.observe(el);
    }
  });
});
</script>


