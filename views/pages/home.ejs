      <p style="font-size:0.82rem;">Free 3-minute cognitive test. How sharp is your brain today?</p>
      <a href="/brain-check" class="btn-game" style="font-size:0.75rem; padding:11px 22px;">Test Your Brain →</a>
    </div>
  </div>
</section>

<!-- Subscribe -->
<section class="subscribe" id="subscribe">
  <div class="section-label">Newsletter</div>
  <h2 class="section-title">Don't miss the next breakthrough</h2>
  <p class="sub-desc">Join 1,000+ scientists, engineers, and investors who read Neural NeXus every week. Free forever.</p>
  <div class="subscribe-form">
    <input type="email" class="subscribe-input" placeholder="you@email.com" id="email-input" autocomplete="email">
    <button class="subscribe-btn" id="subscribe-btn">Subscribe →</button>
  </div>
  <div class="sub-stats">
    <div class="sub-stat">
      <div class="sub-stat-num" style="color:var(--accent);">1,000+</div>
      <div class="sub-stat-label">Subscribers</div>
    </div>
    <div class="sub-stat">
      <div class="sub-stat-num" style="color:var(--accent-2);">Weekly</div>
      <div class="sub-stat-label">Deep dives</div>
    </div>
    <div class="sub-stat">
      <div class="sub-stat-num" style="color:var(--green);">Free</div>
      <div class="sub-stat-label">Always</div>
    </div>
  </div>
  <div class="sub-note">Delivered via Substack · Unsubscribe anytime</div>
</section>
<script>
document.getElementById('subscribe-btn').addEventListener('click', () => {
  const email = document.getElementById('email-input').value.trim();
  window.open(email 
    ? 'https://blog.neuralnexus.press/subscribe?utm_source=neuralnexus&utm_medium=cta&utm_campaign=home-subscribe&email=' + encodeURIComponent(email) 
    : 'https://blog.neuralnexus.press/subscribe?utm_source=neuralnexus&utm_medium=cta&utm_campaign=home-subscribe', '_blank');
});
document.getElementById('email-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') document.getElementById('subscribe-btn').click();
});

window.addEventListener('load', () => {
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.card, .about-card, .game-card, .article-card').forEach(el => {
  el.style.opacity = '0'; el.style.transform = 'translateY(16px)';
  el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
  observer.observe(el);
});
});
</script>


