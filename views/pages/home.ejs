<!-- Articles -->
<section class="section-wrap" id="articles">
  <div class="section-label">Latest</div>
  <h2 class="section-title">Recent deep dives</h2>
  <div class="article-grid">
    <% (locals.featuredArticles || []).forEach(function(article, idx) { %>
    <a href="<%= article.url %>" target="_blank" rel="noopener noreferrer" class="article-card<%= idx === 0 ? ' article-card-featured' : '' %>">
      <div class="article-meta">
        <% if (idx === 0) { %><div class="article-flag">Latest</div><% } %>
        <div class="article-date"><%= new Date(article.date + 'T12:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
        <h3><%= article.title %></h3>
        <p class="desc"><%= article.description %></p>
        <div class="article-cta">Read →</div>
      </div>
      <% if (article.thumbnail) { %>
      <img class="article-thumb" src="<%= article.thumbnail %>" alt="<%= article.title %>" loading="lazy" width="720" height="405">
      <% } %>
    </a>
    <% }); %>
  </div>
  <div class="archive-link">
    <a href="/archive">Explore the on-site archive →</a>
    <a href="https://blog.neuralnexus.press/archive" target="_blank" rel="noopener noreferrer">View the full Substack archive →</a>
  </div>
</section>

