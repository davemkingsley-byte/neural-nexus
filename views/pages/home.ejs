<!-- Topics -->
<section class="section-wrap" id="topics">
  <div class="section-label">Coverage</div>
  <h2 class="section-title">What we write about</h2>
  <div class="card-grid">
    <div class="card">
      <span class="card-icon">🧬</span>
      <h3>Biotech & De-Extinction</h3>
      <p>Gene editing, synthetic biology, artificial wombs, and bringing species back from the dead.</p>
    </div>
    <div class="card">
      <span class="card-icon">🧠</span>
      <h3>Artificial Intelligence</h3>
      <p>Foundation models, agents, and AGI. What's real, what's hype, and what actually matters.</p>
    </div>
    <div class="card">
      <span class="card-icon">🏥</span>
      <h3>Health & Longevity</h3>
      <p>Drug discovery, bioinformatics, personalized medicine, and the science of living longer.</p>
    </div>
    <div class="card">
      <span class="card-icon">🤖</span>
      <h3>Robotics</h3>
      <p>Humanoids, automation, and the machines reshaping labor and daily life.</p>
    </div>
    <div class="card">
      <span class="card-icon">⚡</span>
      <h3>Semiconductors</h3>
      <p>Chip wars, fab capacity, compute economics, and the silicon powering everything.</p>
    </div>
    <div class="card">
      <span class="card-icon">🔮</span>
      <h3>The Future</h3>
      <p>Connecting dots between breakthroughs. The big picture of where this is all going.</p>
    </div>
  </div>
</section>

<!-- Games -->
