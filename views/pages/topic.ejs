<%
  const topicArticles = (locals.topicArticles || []).slice(0, 20);
  const relatedArticles = locals.relatedArticles || [];
%>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "<%= topic.name %>",
  "description": "<%= topic.description %>",
  "url": "https://www.neuralnexus.press/topics/<%= topic.slug %>",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Neural NeXus",
    "url": "https://www.neuralnexus.press"
  },
  "about": {
    "@type": "Thing",
    "name": "<%= topic.name %>"
  },
  "author": {
    "@type": "Person",
    "name": "David Kingsley"
  }
}
</script>

<section class="topic-hero">
  <div class="topic-shell">
    <%- include('../partials/breadcrumb', {
      items: [
        { label: 'Home', href: '/' },
        { label: 'Topics', href: '/topics' },
        { label: topic.name }
      ]
    }) %>

    <div class="topic-hero-card">
      <div class="topic-kicker"><span class="topic-kicker-emoji"><%= topic.emoji %></span> Topic Guide</div>
      <h1><span class="topic-highlight"><%= topic.name %></span><br><%= topic.headline %></h1>
      <p class="topic-description"><%= topic.description %></p>

      <div class="topic-meta-row">
        <div class="topic-author">
          <img src="/img/david.jpg" alt="David Kingsley, PhD">
          <div>
            <div class="topic-author-name">David Kingsley, PhD</div>
            <div class="topic-author-role">Scientist · Neural NeXus</div>
          </div>
        </div>
        <div class="topic-slug-tag">/<%= topic.slug %></div>
      </div>
    </div>
  </div>
</section>

<section class="topic-content-section">
  <div class="topic-shell">
    <div class="topic-content-grid">
      <article class="topic-main-card">
        <div class="section-label">Overview</div>
        <h2 class="topic-section-title">Why <%= topic.name %> matters</h2>
        <p>
          Neural NeXus tracks <strong><%= topic.name %></strong> through the lens of science, technology, and first-order consequences.
          This page is the home base for coverage, key ideas, and the breakthroughs worth watching.
        </p>
        <p>
          Every article below is pulled from the shared editorial index and tagged into this topic hub automatically.
          That means the archive, topic pages, and feed now point at the same source of truth.
        </p>

        <div class="topic-callout">
          <p><strong>Coverage lens:</strong> explainers, market context, frontier research, and practical analysis on <%= topic.name.toLowerCase() %>.</p>
        </div>
      </article>

      <aside class="topic-side-card">
        <div class="section-label">Snapshot</div>
        <ul class="topic-facts">
          <li><span>Topic</span><strong><%= topic.name %></strong></li>
          <li><span>Signal</span><strong><%= topic.headline %></strong></li>
          <li><span>Articles</span><strong><%= topicArticles.length %> recent matches</strong></li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<section class="topic-articles-section">
  <div class="topic-shell">
    <div class="section-label">Articles</div>
    <div class="topic-section-head">
      <div>
        <h2 class="topic-section-title">Latest <%= topic.name %> coverage</h2>
        <p>Newest tagged articles, sorted from most recent to oldest.</p>
      </div>
      <a href="/archive?topic=<%= topic.slug %>" class="topic-section-link">View all in archive →</a>
    </div>

    <% if (topicArticles.length) { %>
      <div class="topic-article-grid">
        <% topicArticles.forEach((article) => { %>
          <article class="topic-article-card">
            <a href="<%= article.url %>" target="_blank" rel="noopener noreferrer" class="topic-article-link">
              <% if (article.thumbnail) { %>
                <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="topic-article-thumb" loading="lazy">
              <% } %>
              <div class="topic-article-body">
                <div class="topic-article-meta">
                  <span><%= article.date %></span>
                  <span class="topic-article-type"><%= article.type %></span>
                </div>
                <h3><%= article.title %></h3>
                <p><%= article.description %></p>
                <div class="topic-article-tags">
                  <% (article.topics || []).forEach((topicSlug) => { %>
                    <span><%= topicSlug %></span>
                  <% }) %>
                </div>
                <span class="topic-related-link">Read on Substack →</span>
              </div>
            </a>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="topic-empty-card">
        <h3>No tagged articles yet</h3>
        <p>This topic hub is live, but the article index does not have any posts tagged to <%= topic.name %> yet.</p>
      </div>
    <% } %>
  </div>
</section>

<% if (relatedArticles.length) { %>
<section class="topic-articles-section">
  <div class="topic-shell">
    <div class="section-label">Related Reading</div>
    <div class="topic-section-head">
      <div>
        <h2 class="topic-section-title">Adjacent articles worth reading</h2>
        <p>Picked from related topics to keep people moving through the broader thesis.</p>
      </div>
    </div>

    <div class="topic-article-grid related-article-grid">
      <% relatedArticles.forEach((article) => { %>
        <article class="topic-article-card related-article-card">
          <a href="<%= article.url %>" target="_blank" rel="noopener noreferrer" class="topic-article-link">
            <% if (article.thumbnail) { %>
              <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="topic-article-thumb" loading="lazy">
            <% } %>
            <div class="topic-article-body">
              <div class="topic-article-meta">
                <span><%= article.date %></span>
                <span class="topic-article-type"><%= article.type %></span>
              </div>
              <h3><%= article.title %></h3>
              <p><%= article.description %></p>
              <span class="topic-related-link">Read on Substack →</span>
            </div>
          </a>
        </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<% if (relatedTopics && relatedTopics.length) { %>
<section class="topic-related-section">
  <div class="topic-shell">
    <div class="section-label">Related Topics</div>
    <h2 class="topic-section-title">Explore adjacent territory</h2>
    <div class="topic-related-grid">
      <% relatedTopics.forEach((relatedTopic) => { %>
        <a href="/topics/<%= relatedTopic.slug %>" class="topic-related-card">
          <span class="topic-related-icon"><%= relatedTopic.emoji %></span>
          <h3><%= relatedTopic.name %></h3>
          <p><%= relatedTopic.description %></p>
          <span class="topic-related-link">Explore topic →</span>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>
