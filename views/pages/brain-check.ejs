<script>
(function() {
  'use strict';

  // ---- State ----
  const state = {
    pvtRTs: [],
    stroopCorrect: 0,
    stroopTotal: 0,
    stroopRTs: [],
    dsstCorrect: 0
  };

  let pvtTrialCount = 0;
  let pvtTimeout = null;
  let pvtGreenTime = 0;
  let pvtPhase = 'idle'; // idle, waiting, ready, result, too-early

  let stroopTrial = 0;
  let stroopStartTime = 0;
  let stroopCurrentInk = '';
  let stroopLocked = false;

  let dsstMapping = {};
  let dsstSymbols = [];
  let dsstCurrentDigit = 0;
  let dsstTimerInterval = null;
  let dsstTimeLeft = 30;
  let dsstRunning = false;

  // ---- Helpers ----
  const $ = id => document.getElementById(id);
  const screens = ['landing', 'pvt', 'stroop', 'dsst', 'results'];

  function showScreen(id) {
    screens.forEach(s => {
      const el = $(s);
      el.classList.remove('active');
    });
    const target = $(id);
    target.classList.add('active');
    target.classList.add('fade-in');
    window.scrollTo(0, 0);
  }

  function median(arr) {
    if (!arr.length) return 0;
    const sorted = [...arr].sort((a, b) => a - b);
    const mid = Math.floor(sorted.length / 2);
    return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
  }

  function lerp(value, minVal, maxVal, minScore, maxScore) {
    if (value <= minVal) return maxScore;
    if (value >= maxVal) return minScore;
    return maxScore - ((value - minVal) / (maxVal - minVal)) * (maxScore - minScore);
  }

  function shuffleArray(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  // Debounce helper for mobile double-tap prevention
  let lastTapTime = 0;
  function debounced() {
    const now = performance.now();
    if (now - lastTapTime < 200) return true;
    lastTapTime = now;
    return false;
  }

  // ---- START ----
  $('btn-start').addEventListener('click', function() {
    if (debounced()) return;
    try { gtag('event', 'brain_check_start', {}); } catch(e) {}
    startPVT();
  });

  // ==================== PVT ====================
  function startPVT() {
    showScreen('pvt');
    pvtTrialCount = 0;
    state.pvtRTs = [];
    pvtPhase = 'idle';
    updatePVTDisplay();
  }

  function updatePVTDisplay() {
    $('pvt-counter').textContent = pvtTrialCount + ' / 5';
  }

  function pvtStartWaiting() {
    const area = $('pvt-area');
    area.className = 'waiting';
    $('pvt-msg').textContent = 'Wait...';
    pvtPhase = 'waiting';

    const delay = 2000 + Math.random() * 6000;
    pvtTimeout = setTimeout(function() {
      area.className = 'ready';
      $('pvt-msg').textContent = 'TAP NOW!';
      pvtGreenTime = performance.now();
      pvtPhase = 'ready';
    }, delay);
  }

  $('pvt-area').addEventListener('click', function() {
    if (debounced()) return;
    const area = $('pvt-area');

    if (pvtPhase === 'idle') {
      pvtStartWaiting();
      return;
    }

    if (pvtPhase === 'waiting') {
      // False start
      clearTimeout(pvtTimeout);
      area.className = 'too-early';
      $('pvt-msg').textContent = 'Too early!';
      pvtPhase = 'too-early';
      setTimeout(function() {
        pvtStartWaiting();
      }, 1200);
      return;
    }

    if (pvtPhase === 'too-early') return;

    if (pvtPhase === 'ready') {
      const rt = Math.round(performance.now() - pvtGreenTime);
      state.pvtRTs.push(rt);
      pvtTrialCount++;
      updatePVTDisplay();

      area.className = 'result';
      $('pvt-msg').textContent = rt + ' ms';
      pvtPhase = 'result';

      if (pvtTrialCount >= 5) {
        setTimeout(function() { startStroop(); }, 1200);
      } else {
        setTimeout(function() { pvtStartWaiting(); }, 1200);
      }
      return;
    }

    if (pvtPhase === 'result') return;
  });

  // ==================== STROOP ====================
  const stroopColors = [
    { name: 'red', hex: '#ff4444' },
    { name: 'blue', hex: '#4488ff' },
    { name: 'green', hex: '#44ff88' },
    { name: 'yellow', hex: '#ffdd44' }
  ];

  function startStroop() {
    showScreen('stroop');
    stroopTrial = 0;
    state.stroopCorrect = 0;
    state.stroopTotal = 0;
    state.stroopRTs = [];
    stroopLocked = false;
    nextStroopTrial();
  }

  function nextStroopTrial() {
    if (stroopTrial >= 10) {
      setTimeout(function() { startDSST(); }, 800);
      return;
    }

    $('stroop-counter').textContent = stroopTrial + ' / 10';
    $('stroop-feedback').textContent = '';

    // Pick word and ink color (must be different for incongruent)
    let wordIdx, inkIdx;
    do {
      wordIdx = Math.floor(Math.random() * 4);
      inkIdx = Math.floor(Math.random() * 4);
    } while (wordIdx === inkIdx);

    const wordEl = $('stroop-word');
    wordEl.textContent = stroopColors[wordIdx].name.toUpperCase();
    wordEl.style.color = stroopColors[inkIdx].hex;

    stroopCurrentInk = stroopColors[inkIdx].name;
    stroopStartTime = performance.now();
    stroopLocked = false;
  }

  $('stroop-buttons').addEventListener('click', function(e) {
    const btn = e.target.closest('.stroop-btn');
    if (!btn || stroopLocked) return;
    if (debounced()) return;

    stroopLocked = true;
    const chosen = btn.dataset.color;
    const rt = Math.round(performance.now() - stroopStartTime);
    state.stroopRTs.push(rt);
    state.stroopTotal++;
    stroopTrial++;

    const fb = $('stroop-feedback');
    if (chosen === stroopCurrentInk) {
      state.stroopCorrect++;
      fb.textContent = 'Correct!';
      fb.style.color = 'var(--green)';
    } else {
      fb.textContent = 'Wrong — it was ' + stroopCurrentInk;
      fb.style.color = 'var(--red)';
    }

    setTimeout(nextStroopTrial, 800);
  });

  // ==================== DSST ====================
  const allSymbols = ['!', '@', '#', '$', '%', '^', '&', '*', '+'];

  function startDSST() {
    showScreen('dsst');
    state.dsstCorrect = 0;
    dsstTimeLeft = 30;
    dsstRunning = false;

    // Randomize symbol mapping
    const shuffled = shuffleArray([...allSymbols]);
    dsstMapping = {};
    dsstSymbols = shuffled;
    for (let i = 0; i < 9; i++) {
      dsstMapping[i + 1] = shuffled[i];
    }

    // Build key display
    const keyEl = $('dsst-key');
    keyEl.innerHTML = '';
    for (let d = 1; d <= 9; d++) {
      const item = document.createElement('div');
      item.className = 'dsst-key-item';
      item.innerHTML = '<div class="dsst-key-digit">' + d + '</div><div class="dsst-key-symbol">' + dsstMapping[d] + '</div>';
      keyEl.appendChild(item);
    }

    // Build button grid
    const gridEl = $('dsst-grid');
    gridEl.innerHTML = '';
    for (let i = 0; i < 9; i++) {
      const btn = document.createElement('button');
      btn.className = 'dsst-btn';
      btn.textContent = shuffled[i];
      btn.dataset.symbol = shuffled[i];
      gridEl.appendChild(btn);
    }

    $('dsst-score').textContent = '0';
    $('dsst-time').textContent = '30';
    nextDSSTDigit();
    startDSSTTimer();
  }

  function nextDSSTDigit() {
    dsstCurrentDigit = Math.floor(Math.random() * 9) + 1;
    $('dsst-prompt').textContent = dsstCurrentDigit;
  }

  function startDSSTTimer() {
    dsstRunning = true;
    dsstTimerInterval = setInterval(function() {
      dsstTimeLeft--;
      $('dsst-time').textContent = dsstTimeLeft;
      if (dsstTimeLeft <= 0) {
        clearInterval(dsstTimerInterval);
        dsstRunning = false;
        setTimeout(showResults, 600);
      }
    }, 1000);
  }

  $('dsst-grid').addEventListener('click', function(e) {
    const btn = e.target.closest('.dsst-btn');
    if (!btn || !dsstRunning) return;
    if (debounced()) return;

    const chosen = btn.dataset.symbol;
    const correct = dsstMapping[dsstCurrentDigit];

    if (chosen === correct) {
      state.dsstCorrect++;
      $('dsst-score').textContent = state.dsstCorrect;
      btn.classList.add('correct-flash');
      setTimeout(() => btn.classList.remove('correct-flash'), 200);
    } else {
      btn.classList.add('wrong-flash');
      setTimeout(() => btn.classList.remove('wrong-flash'), 200);
    }

    nextDSSTDigit();
  });

  // ==================== RESULTS ====================
  function calcPVTScore(medianRT) {
    if (medianRT < 250) return 100;
    if (medianRT <= 300) return lerp(medianRT, 250, 300, 100, 80);
    if (medianRT <= 350) return lerp(medianRT, 300, 350, 80, 60);
    if (medianRT <= 400) return lerp(medianRT, 350, 400, 60, 40);
    return 20;
  }

  function calcStroopScore(accuracy) {
    if (accuracy >= 1.0) return 100;
    if (accuracy >= 0.9) return lerp(1.0 - accuracy, 0, 0.1, 100, 70);
    if (accuracy >= 0.8) return lerp(1.0 - accuracy, 0.1, 0.2, 70, 50);
    if (accuracy >= 0.7) return lerp(1.0 - accuracy, 0.2, 0.3, 50, 20);
    return 20;
  }

  function calcDSSTScore(correct) {
    if (correct > 20) return 100;
    if (correct >= 15) return lerp(20 - correct, 0, 5, 100, 80);
    if (correct >= 10) return lerp(15 - correct, 0, 5, 80, 60);
    if (correct >= 5) return lerp(10 - correct, 0, 5, 60, 40);
    return 20;
  }

  function getLabel(score) {
    if (score >= 80) return { text: 'Excellent', cls: 'label-excellent' };
    if (score >= 60) return { text: 'Good', cls: 'label-good' };
    if (score >= 40) return { text: 'Average', cls: 'label-average' };
    return { text: 'Below Average', cls: 'label-below' };
  }

  function getPercentile(score) {
    if (score >= 90) return 95;
    if (score >= 80) return 85;
    if (score >= 70) return 70;
    if (score >= 60) return 50;
    if (score >= 50) return 35;
    return 20;
  }

  function showResults() {
    showScreen('results');

    const medRT = Math.round(median(state.pvtRTs));
    const stroopAcc = state.stroopTotal > 0 ? state.stroopCorrect / state.stroopTotal : 0;

    const pvtScore = calcPVTScore(medRT);
    const stroopScore = calcStroopScore(stroopAcc);
    const dsstScore = calcDSSTScore(state.dsstCorrect);

    const finalScore = Math.round((pvtScore + stroopScore + dsstScore) / 3);

    try { gtag('event', 'brain_check_complete', { score: finalScore }); } catch(e) {}

    // Animate score
    const scoreEl = $('score-big');
    let current = 0;
    const step = Math.max(1, Math.floor(finalScore / 40));
    const scoreAnim = setInterval(function() {
      current += step;
      if (current >= finalScore) {
        current = finalScore;
        clearInterval(scoreAnim);
      }
      scoreEl.textContent = current;
    }, 30);

    // Percentile
    const pct = getPercentile(finalScore);
    $('percentile-badge').textContent = 'You scored better than ' + pct + '% of test-takers';

    // Breakdown cards
    const pvtLabel = getLabel(pvtScore);
    const stroopLabel = getLabel(stroopScore);
    const dsstLabel = getLabel(dsstScore);

    $('breakdown').innerHTML =
      '<div class="breakdown-card fade-in">' +
        '<div class="card-icon">&#9889;</div>' +
        '<div class="card-title">Reaction Time</div>' +
        '<div class="card-value">' + medRT + ' ms</div>' +
        '<div class="card-label ' + pvtLabel.cls + '">' + pvtLabel.text + '</div>' +
      '</div>' +
      '<div class="breakdown-card fade-in">' +
        '<div class="card-icon">&#127919;</div>' +
        '<div class="card-title">Focus</div>' +
        '<div class="card-value">' + Math.round(stroopAcc * 100) + '%</div>' +
        '<div class="card-label ' + stroopLabel.cls + '">' + stroopLabel.text + '</div>' +
      '</div>' +
      '<div class="breakdown-card fade-in">' +
        '<div class="card-icon">&#9889;</div>' +
        '<div class="card-title">Processing Speed</div>' +
        '<div class="card-value">' + state.dsstCorrect + '</div>' +
        '<div class="card-label ' + dsstLabel.cls + '">' + dsstLabel.text + '</div>' +
      '</div>';

    // Streak: update and display
    var newStreak = updateStreak();
    window._currentScore = finalScore;
    if (newStreak >= 2) {
      $('result-streak-text').textContent = '🔥 ' + newStreak + '-day streak!';
      $('result-streak-wrap').style.display = '';
    }

    // Share data — personalized by score tier
    var shareVerb = finalScore >= 80 ? 'crushed' : finalScore >= 60 ? 'scored' : 'scored';
    var shareEmoji = finalScore >= 80 ? '🔥' : finalScore >= 60 ? '🧠' : '💪';
    window._shareText = shareEmoji + ' I ' + shareVerb + ' ' + finalScore + '/100 on the Neural NeXus Brain Check! How sharp is your brain? \uD83E\uDDE0 https://www.neuralnexus.press/brain-check/';

    // Confetti
    launchConfetti();

    // Submit to leaderboard (non-blocking)
    fetch('/api/brain-check/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ score: finalScore, pvt_ms: medRT, dsst_score: state.dsstCorrect })
    })
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(data) {
      if (!data) return;
      var el = $('percentile-live');
      if (data.total < 5) {
        el.textContent = 'You are one of our first testers!';
      } else {
        el.textContent = 'You scored better than ' + data.percentile + '% of Brain Check takers \uD83E\uDDE0';
      }
      el.style.display = 'inline-block';
      // Refresh benchmarks widget
      fetchLeaderboard();
    })
    .catch(function() {});
  }

  // ---- Share ----
  $('btn-share').addEventListener('click', function() {
    if (debounced()) return;
    try { gtag('event', 'brain_check_share', {}); } catch(e) {}

    if (navigator.share) {
      navigator.share({
        title: 'Neural NeXus Brain Check',
        text: window._shareText
      }).catch(function() {});
    } else {
      navigator.clipboard.writeText(window._shareText).then(function() {
        const btn = $('btn-share');
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = orig; }, 2000);
      }).catch(function() {
        prompt('Copy your result:', window._shareText);
      });
    }
  });

  // ---- Take Again ----
  $('btn-again').addEventListener('click', function() {
    if (debounced()) return;
    state.pvtRTs = [];
    state.stroopCorrect = 0;
    state.stroopTotal = 0;
    state.stroopRTs = [];
    state.dsstCorrect = 0;
    showScreen('landing');
  });

  // ==================== CONFETTI ====================
  function launchConfetti() {
    const canvas = $('confetti-canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const particles = [];
    const colors = ['#d4a853', '#f0c060', '#4488ff', '#44ff88', '#ff4444', '#ffdd44', '#ffffff'];

    for (let i = 0; i < 120; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: -20 - Math.random() * 200,
        vx: (Math.random() - 0.5) * 4,
        vy: 2 + Math.random() * 4,
        size: 4 + Math.random() * 6,
        color: colors[Math.floor(Math.random() * colors.length)],
        rotation: Math.random() * 360,
        rotSpeed: (Math.random() - 0.5) * 10,
        life: 1
      });
    }

    let frame = 0;
    function animateConfetti() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;

      particles.forEach(function(p) {
        if (p.life <= 0) return;
        alive = true;

        p.x += p.vx;
        p.vy += 0.08;
        p.y += p.vy;
        p.rotation += p.rotSpeed;

        if (p.y > canvas.height + 20) {
          p.life = 0;
          return;
        }

        // Fade after frame 60
        if (frame > 60) {
          p.life -= 0.015;
        }

        ctx.save();
        ctx.globalAlpha = Math.max(0, p.life);
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation * Math.PI / 180);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.size / 2, -p.size / 4, p.size, p.size / 2);
        ctx.restore();
      });

      frame++;
      if (alive && frame < 200) {
        requestAnimationFrame(animateConfetti);
      } else {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }

    requestAnimationFrame(animateConfetti);
  }

  // ---- Live Benchmarks ----
  function fetchLeaderboard() {
    fetch('/api/brain-check/leaderboard')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (!data || data.total === 0) return;
        $('live-benchmarks').style.display = '';
        $('lb-total').textContent = data.total;
        $('lb-median').textContent = data.percentiles.p50 != null ? data.percentiles.p50 : '—';
        $('lb-p75').textContent = data.percentiles.p75 != null ? data.percentiles.p75 : '—';
        $('lb-p90').textContent = data.percentiles.p90 != null ? data.percentiles.p90 : '—';
      })
      .catch(function() {});
  }
  fetchLeaderboard();

  // ==================== STREAK TRACKING ====================
  function getToday() {
    return new Date().toISOString().split('T')[0];
  }

  function updateStreak() {
    var today = getToday();
    var lastDate = localStorage.getItem('nn_bc_last_date');
    var streak = parseInt(localStorage.getItem('nn_bc_streak') || '0', 10);

    if (lastDate === today) {
      // Already tested today — don't increment, just return current streak
      return streak;
    }

    var yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    var yd = yesterday.toISOString().split('T')[0];

    if (lastDate === yd) {
      streak = streak + 1; // Consecutive day
    } else {
      streak = 1; // First time or broke streak
    }

    localStorage.setItem('nn_bc_streak', String(streak));
    localStorage.setItem('nn_bc_last_date', today);
    return streak;
  }

  function getExistingStreak() {
    var today = getToday();
    var lastDate = localStorage.getItem('nn_bc_last_date');
    var streak = parseInt(localStorage.getItem('nn_bc_streak') || '0', 10);

    if (!lastDate || streak === 0) return 0;

    // Show streak badge on landing if tested yesterday or today
    var yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    var yd = yesterday.toISOString().split('T')[0];

    if (lastDate === today || lastDate === yd) return streak;
    return 0;
  }

  // Show streak badge on landing page if returning user
  (function() {
    var s = getExistingStreak();
    if (s >= 2) {
      $('landing-streak-text').textContent = 'Day ' + s + ' streak';
      $('landing-streak-wrap').style.display = '';
    }
  })();

  // ==================== EMAIL CAPTURE ====================
  var _emailModalShown = false;

  function shouldShowEmailModal() {
    // Don't show if user already subscribed or dismissed recently
    var dismissed = localStorage.getItem('nn_email_dismissed');
    var subscribed = localStorage.getItem('nn_subscribed');
    if (subscribed === '1') return false;
    if (dismissed) {
      var dismissedAt = parseInt(dismissed, 10);
      var sevenDays = 7 * 24 * 60 * 60 * 1000;
      if (Date.now() - dismissedAt < sevenDays) return false;
    }
    return true;
  }

  function showEmailModal() {
    if (_emailModalShown) return;
    if (!shouldShowEmailModal()) return;
    _emailModalShown = true;
    $('email-modal-overlay').classList.add('visible');
    try { gtag('event', 'email_modal_shown', {}); } catch(e) {}
  }

  function hideEmailModal() {
    $('email-modal-overlay').classList.remove('visible');
  }

  function dismissEmailModal() {
    localStorage.setItem('nn_email_dismissed', String(Date.now()));
    hideEmailModal();
    try { gtag('event', 'email_modal_dismissed', {}); } catch(e) {}
  }

  // Show modal after results + 2.5 second delay
  var _origShowResults = showResults;
  // Trigger modal when results screen is shown
  // Poll for results screen becoming active (triggered from showResults → showScreen)
  var _modalScheduled = false;
  (function scheduleModalCheck() {
    var interval = setInterval(function() {
      if ($('results').classList.contains('active') && !_modalScheduled) {
        _modalScheduled = true;
        clearInterval(interval);
        setTimeout(showEmailModal, 2800);
      }
    }, 200);
    // Stop checking after 5 minutes
    setTimeout(function() { clearInterval(interval); }, 300000);
  })();

  $('email-modal-close').addEventListener('click', dismissEmailModal);
  $('email-modal-skip').addEventListener('click', dismissEmailModal);

  $('btn-subscribe').addEventListener('click', function() {
    var emailInput = $('email-modal-input');
    var email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      emailInput.style.borderColor = '#ff4444';
      emailInput.focus();
      setTimeout(function() { emailInput.style.borderColor = ''; }, 2000);
      return;
    }

    var btn = $('btn-subscribe');
    btn.textContent = '...';
    btn.disabled = true;

    fetch('/api/brain-check/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, score: window._currentScore || null })
    })
    .then(function(r) { return r.ok ? r.json() : { ok: false }; })
    .then(function(data) {
      // Mark as subscribed regardless (even if duplicate)
      localStorage.setItem('nn_subscribed', '1');
      $('email-modal-form-wrap').style.display = 'none';
      $('email-modal-success').style.display = '';
      try { gtag('event', 'email_subscribed', { email: email }); } catch(e) {}
      // Auto-close after 3 seconds
      setTimeout(hideEmailModal, 3000);
    })
    .catch(function() {
      btn.textContent = 'Subscribe →';
      btn.disabled = false;
    });
  });

  // Allow submit on Enter key in email input
  $('email-modal-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') $('btn-subscribe').click();
  });

})();
</script>
</div>

<script>
(function() {
  'use strict';

  // ---- State ----
  const state = {
    pvtRTs: [],
    stroopCorrect: 0,
    stroopTotal: 0,
    stroopRTs: [],
    dsstCorrect: 0
  };

  let pvtTrialCount = 0;
  let pvtTimeout = null;
  let pvtGreenTime = 0;
  let pvtPhase = 'idle'; // idle, waiting, ready, result, too-early

  let stroopTrial = 0;
  let stroopStartTime = 0;
  let stroopCurrentInk = '';
  let stroopLocked = false;

  let dsstMapping = {};
  let dsstSymbols = [];
  let dsstCurrentDigit = 0;
  let dsstTimerInterval = null;
  let dsstTimeLeft = 30;
  let dsstRunning = false;

  // ---- Helpers ----
  const $ = id => document.getElementById(id);
  const screens = ['landing', 'pvt', 'stroop', 'dsst', 'results'];

  function showScreen(id) {
    screens.forEach(s => {
      const el = $(s);
      el.classList.remove('active');
    });
    const target = $(id);
    target.classList.add('active');
    target.classList.add('fade-in');
    window.scrollTo(0, 0);
  }

  function median(arr) {
    if (!arr.length) return 0;
    const sorted = [...arr].sort((a, b) => a - b);
    const mid = Math.floor(sorted.length / 2);
    return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
  }

  function lerp(value, minVal, maxVal, minScore, maxScore) {
    if (value <= minVal) return maxScore;
    if (value >= maxVal) return minScore;
    return maxScore - ((value - minVal) / (maxVal - minVal)) * (maxScore - minScore);
  }

  function shuffleArray(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  // Debounce helper for mobile double-tap prevention
  let lastTapTime = 0;
  function debounced() {
    const now = performance.now();
    if (now - lastTapTime < 200) return true;
    lastTapTime = now;
    return false;
  }

  // ---- START ----
  $('btn-start').addEventListener('click', function() {
    if (debounced()) return;
    try { gtag('event', 'brain_check_start', {}); } catch(e) {}
    startPVT();
  });

  // ==================== PVT ====================
  function startPVT() {
    showScreen('pvt');
    pvtTrialCount = 0;
    state.pvtRTs = [];
    pvtPhase = 'idle';
    updatePVTDisplay();
  }

  function updatePVTDisplay() {
    $('pvt-counter').textContent = pvtTrialCount + ' / 5';
  }

  function pvtStartWaiting() {
    const area = $('pvt-area');
    area.className = 'waiting';
    $('pvt-msg').textContent = 'Wait...';
    pvtPhase = 'waiting';

    const delay = 2000 + Math.random() * 6000;
    pvtTimeout = setTimeout(function() {
      area.className = 'ready';
      $('pvt-msg').textContent = 'TAP NOW!';
      pvtGreenTime = performance.now();
      pvtPhase = 'ready';
    }, delay);
  }

  $('pvt-area').addEventListener('click', function() {
    if (debounced()) return;
    const area = $('pvt-area');

    if (pvtPhase === 'idle') {
      pvtStartWaiting();
      return;
    }

    if (pvtPhase === 'waiting') {
      // False start
      clearTimeout(pvtTimeout);
      area.className = 'too-early';
      $('pvt-msg').textContent = 'Too early!';
      pvtPhase = 'too-early';
      setTimeout(function() {
        pvtStartWaiting();
      }, 1200);
      return;
    }

    if (pvtPhase === 'too-early') return;

    if (pvtPhase === 'ready') {
      const rt = Math.round(performance.now() - pvtGreenTime);
      state.pvtRTs.push(rt);
      pvtTrialCount++;
      updatePVTDisplay();

      area.className = 'result';
      $('pvt-msg').textContent = rt + ' ms';
      pvtPhase = 'result';

      if (pvtTrialCount >= 5) {
        setTimeout(function() { startStroop(); }, 1200);
      } else {
        setTimeout(function() { pvtStartWaiting(); }, 1200);
      }
      return;
    }

    if (pvtPhase === 'result') return;
  });

  // ==================== STROOP ====================
  const stroopColors = [
    { name: 'red', hex: '#ff4444' },
    { name: 'blue', hex: '#4488ff' },
    { name: 'green', hex: '#44ff88' },
    { name: 'yellow', hex: '#ffdd44' }
  ];

  function startStroop() {
    showScreen('stroop');
    stroopTrial = 0;
    state.stroopCorrect = 0;
    state.stroopTotal = 0;
    state.stroopRTs = [];
    stroopLocked = false;
    nextStroopTrial();
  }

  function nextStroopTrial() {
    if (stroopTrial >= 10) {
      setTimeout(function() { startDSST(); }, 800);
      return;
    }

    $('stroop-counter').textContent = stroopTrial + ' / 10';
    $('stroop-feedback').textContent = '';

    // Pick word and ink color (must be different for incongruent)
    let wordIdx, inkIdx;
    do {
      wordIdx = Math.floor(Math.random() * 4);
      inkIdx = Math.floor(Math.random() * 4);
    } while (wordIdx === inkIdx);

    const wordEl = $('stroop-word');
    wordEl.textContent = stroopColors[wordIdx].name.toUpperCase();
    wordEl.style.color = stroopColors[inkIdx].hex;

    stroopCurrentInk = stroopColors[inkIdx].name;
    stroopStartTime = performance.now();
    stroopLocked = false;
  }

  $('stroop-buttons').addEventListener('click', function(e) {
    const btn = e.target.closest('.stroop-btn');
    if (!btn || stroopLocked) return;
    if (debounced()) return;

    stroopLocked = true;
    const chosen = btn.dataset.color;
    const rt = Math.round(performance.now() - stroopStartTime);
    state.stroopRTs.push(rt);
    state.stroopTotal++;
    stroopTrial++;

    const fb = $('stroop-feedback');
    if (chosen === stroopCurrentInk) {
      state.stroopCorrect++;
      fb.textContent = 'Correct!';
      fb.style.color = 'var(--green)';
    } else {
      fb.textContent = 'Wrong — it was ' + stroopCurrentInk;
      fb.style.color = 'var(--red)';
    }

    setTimeout(nextStroopTrial, 800);
  });

  // ==================== DSST ====================
  const allSymbols = ['!', '@', '#', '$', '%', '^', '&', '*', '+'];

  function startDSST() {
    showScreen('dsst');
    state.dsstCorrect = 0;
    dsstTimeLeft = 30;
    dsstRunning = false;

    // Randomize symbol mapping
    const shuffled = shuffleArray([...allSymbols]);
    dsstMapping = {};
    dsstSymbols = shuffled;
    for (let i = 0; i < 9; i++) {
      dsstMapping[i + 1] = shuffled[i];
    }

    // Build key display
    const keyEl = $('dsst-key');
    keyEl.innerHTML = '';
    for (let d = 1; d <= 9; d++) {
      const item = document.createElement('div');
      item.className = 'dsst-key-item';
      item.innerHTML = '<div class="dsst-key-digit">' + d + '</div><div class="dsst-key-symbol">' + dsstMapping[d] + '</div>';
      keyEl.appendChild(item);
    }

    // Build button grid
    const gridEl = $('dsst-grid');
    gridEl.innerHTML = '';
    for (let i = 0; i < 9; i++) {
      const btn = document.createElement('button');
      btn.className = 'dsst-btn';
      btn.textContent = shuffled[i];
      btn.dataset.symbol = shuffled[i];
      gridEl.appendChild(btn);
    }

    $('dsst-score').textContent = '0';
    $('dsst-time').textContent = '30';
    nextDSSTDigit();
    startDSSTTimer();
  }

  function nextDSSTDigit() {
    dsstCurrentDigit = Math.floor(Math.random() * 9) + 1;
    $('dsst-prompt').textContent = dsstCurrentDigit;
  }

  function startDSSTTimer() {
    dsstRunning = true;
    dsstTimerInterval = setInterval(function() {
      dsstTimeLeft--;
      $('dsst-time').textContent = dsstTimeLeft;
      if (dsstTimeLeft <= 0) {
        clearInterval(dsstTimerInterval);
        dsstRunning = false;
        setTimeout(showResults, 600);
      }
    }, 1000);
  }

  $('dsst-grid').addEventListener('click', function(e) {
    const btn = e.target.closest('.dsst-btn');
    if (!btn || !dsstRunning) return;
    if (debounced()) return;

    const chosen = btn.dataset.symbol;
    const correct = dsstMapping[dsstCurrentDigit];

    if (chosen === correct) {
      state.dsstCorrect++;
      $('dsst-score').textContent = state.dsstCorrect;
      btn.classList.add('correct-flash');
      setTimeout(() => btn.classList.remove('correct-flash'), 200);
    } else {
      btn.classList.add('wrong-flash');
      setTimeout(() => btn.classList.remove('wrong-flash'), 200);
    }

    nextDSSTDigit();
  });

  // ==================== RESULTS ====================
  function calcPVTScore(medianRT) {
    if (medianRT < 250) return 100;
    if (medianRT <= 300) return lerp(medianRT, 250, 300, 100, 80);
    if (medianRT <= 350) return lerp(medianRT, 300, 350, 80, 60);
    if (medianRT <= 400) return lerp(medianRT, 350, 400, 60, 40);
    return 20;
  }

  function calcStroopScore(accuracy) {
    if (accuracy >= 1.0) return 100;
    if (accuracy >= 0.9) return lerp(1.0 - accuracy, 0, 0.1, 100, 70);
    if (accuracy >= 0.8) return lerp(1.0 - accuracy, 0.1, 0.2, 70, 50);
    if (accuracy >= 0.7) return lerp(1.0 - accuracy, 0.2, 0.3, 50, 20);
    return 20;
  }

  function calcDSSTScore(correct) {
    if (correct > 20) return 100;
    if (correct >= 15) return lerp(20 - correct, 0, 5, 100, 80);
    if (correct >= 10) return lerp(15 - correct, 0, 5, 80, 60);
    if (correct >= 5) return lerp(10 - correct, 0, 5, 60, 40);
    return 20;
  }

  function getLabel(score) {
    if (score >= 80) return { text: 'Excellent', cls: 'label-excellent' };
    if (score >= 60) return { text: 'Good', cls: 'label-good' };
    if (score >= 40) return { text: 'Average', cls: 'label-average' };
    return { text: 'Below Average', cls: 'label-below' };
  }

  function getPercentile(score) {
    if (score >= 90) return 95;
    if (score >= 80) return 85;
    if (score >= 70) return 70;
    if (score >= 60) return 50;
    if (score >= 50) return 35;
    return 20;
  }

  function showResults() {
    showScreen('results');

    const medRT = Math.round(median(state.pvtRTs));
    const stroopAcc = state.stroopTotal > 0 ? state.stroopCorrect / state.stroopTotal : 0;

    const pvtScore = calcPVTScore(medRT);
    const stroopScore = calcStroopScore(stroopAcc);
    const dsstScore = calcDSSTScore(state.dsstCorrect);

    const finalScore = Math.round((pvtScore + stroopScore + dsstScore) / 3);

    try { gtag('event', 'brain_check_complete', { score: finalScore }); } catch(e) {}

    // Animate score
    const scoreEl = $('score-big');
    let current = 0;
    const step = Math.max(1, Math.floor(finalScore / 40));
    const scoreAnim = setInterval(function() {
      current += step;
      if (current >= finalScore) {
        current = finalScore;
        clearInterval(scoreAnim);
      }
      scoreEl.textContent = current;
    }, 30);

    // Percentile
    const pct = getPercentile(finalScore);
    $('percentile-badge').textContent = 'You scored better than ' + pct + '% of test-takers';

    // Breakdown cards
    const pvtLabel = getLabel(pvtScore);
    const stroopLabel = getLabel(stroopScore);
    const dsstLabel = getLabel(dsstScore);

    $('breakdown').innerHTML =
      '<div class="breakdown-card fade-in">' +
        '<div class="card-icon">&#9889;</div>' +
        '<div class="card-title">Reaction Time</div>' +
        '<div class="card-value">' + medRT + ' ms</div>' +
        '<div class="card-label ' + pvtLabel.cls + '">' + pvtLabel.text + '</div>' +
      '</div>' +
      '<div class="breakdown-card fade-in">' +
        '<div class="card-icon">&#127919;</div>' +
        '<div class="card-title">Focus</div>' +
        '<div class="card-value">' + Math.round(stroopAcc * 100) + '%</div>' +
        '<div class="card-label ' + stroopLabel.cls + '">' + stroopLabel.text + '</div>' +
      '</div>' +
      '<div class="breakdown-card fade-in">' +
        '<div class="card-icon">&#9889;</div>' +
        '<div class="card-title">Processing Speed</div>' +
        '<div class="card-value">' + state.dsstCorrect + '</div>' +
        '<div class="card-label ' + dsstLabel.cls + '">' + dsstLabel.text + '</div>' +
      '</div>';

    // Streak: update and display
    var newStreak = updateStreak();
    window._currentScore = finalScore;
    if (newStreak >= 2) {
      $('result-streak-text').textContent = '🔥 ' + newStreak + '-day streak!';
      $('result-streak-wrap').style.display = '';
    }

    // Share data — personalized by score tier
    var shareVerb = finalScore >= 80 ? 'crushed' : finalScore >= 60 ? 'scored' : 'scored';
    var shareEmoji = finalScore >= 80 ? '🔥' : finalScore >= 60 ? '🧠' : '💪';
    window._shareText = shareEmoji + ' I ' + shareVerb + ' ' + finalScore + '/100 on the Neural NeXus Brain Check! How sharp is your brain? \uD83E\uDDE0 https://www.neuralnexus.press/brain-check/';

    // Confetti
    launchConfetti();

    // Submit to leaderboard (non-blocking)
    fetch('/api/brain-check/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ score: finalScore, pvt_ms: medRT, dsst_score: state.dsstCorrect })
    })
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(data) {
      if (!data) return;
      var el = $('percentile-live');
      if (data.total < 5) {
        el.textContent = 'You are one of our first testers!';
      } else {
        el.textContent = 'You scored better than ' + data.percentile + '% of Brain Check takers \uD83E\uDDE0';
      }
      el.style.display = 'inline-block';
      // Refresh benchmarks widget
      fetchLeaderboard();
    })
    .catch(function() {});
  }

  // ---- Share ----
  $('btn-share').addEventListener('click', function() {
    if (debounced()) return;
    try { gtag('event', 'brain_check_share', {}); } catch(e) {}

    if (navigator.share) {
      navigator.share({
        title: 'Neural NeXus Brain Check',
        text: window._shareText
      }).catch(function() {});
    } else {
      navigator.clipboard.writeText(window._shareText).then(function() {
        const btn = $('btn-share');
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = orig; }, 2000);
      }).catch(function() {
        prompt('Copy your result:', window._shareText);
      });
    }
  });

  // ---- Take Again ----
  $('btn-again').addEventListener('click', function() {
    if (debounced()) return;
    state.pvtRTs = [];
    state.stroopCorrect = 0;
    state.stroopTotal = 0;
    state.stroopRTs = [];
    state.dsstCorrect = 0;
    showScreen('landing');
  });

  // ==================== CONFETTI ====================
  function launchConfetti() {
    const canvas = $('confetti-canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const particles = [];
    const colors = ['#d4a853', '#f0c060', '#4488ff', '#44ff88', '#ff4444', '#ffdd44', '#ffffff'];

    for (let i = 0; i < 120; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: -20 - Math.random() * 200,
        vx: (Math.random() - 0.5) * 4,
        vy: 2 + Math.random() * 4,
        size: 4 + Math.random() * 6,
        color: colors[Math.floor(Math.random() * colors.length)],
        rotation: Math.random() * 360,
        rotSpeed: (Math.random() - 0.5) * 10,
        life: 1
      });
    }

    let frame = 0;
    function animateConfetti() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;

      particles.forEach(function(p) {
        if (p.life <= 0) return;
        alive = true;

        p.x += p.vx;
        p.vy += 0.08;
        p.y += p.vy;
        p.rotation += p.rotSpeed;

        if (p.y > canvas.height + 20) {
          p.life = 0;
          return;
        }

        // Fade after frame 60
        if (frame > 60) {
          p.life -= 0.015;
        }

        ctx.save();
        ctx.globalAlpha = Math.max(0, p.life);
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation * Math.PI / 180);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.size / 2, -p.size / 4, p.size, p.size / 2);
        ctx.restore();
      });

      frame++;
      if (alive && frame < 200) {
        requestAnimationFrame(animateConfetti);
      } else {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }

    requestAnimationFrame(animateConfetti);
  }

  // ---- Live Benchmarks ----
  function fetchLeaderboard() {
    fetch('/api/brain-check/leaderboard')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (!data || data.total === 0) return;
        $('live-benchmarks').style.display = '';
        $('lb-total').textContent = data.total;
        $('lb-median').textContent = data.percentiles.p50 != null ? data.percentiles.p50 : '—';
        $('lb-p75').textContent = data.percentiles.p75 != null ? data.percentiles.p75 : '—';
        $('lb-p90').textContent = data.percentiles.p90 != null ? data.percentiles.p90 : '—';
      })
      .catch(function() {});
  }
  fetchLeaderboard();

  // ==================== STREAK TRACKING ====================
  function getToday() {
    return new Date().toISOString().split('T')[0];
  }

  function updateStreak() {
    var today = getToday();
    var lastDate = localStorage.getItem('nn_bc_last_date');
    var streak = parseInt(localStorage.getItem('nn_bc_streak') || '0', 10);

    if (lastDate === today) {
      // Already tested today — don't increment, just return current streak
      return streak;
    }

    var yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    var yd = yesterday.toISOString().split('T')[0];

    if (lastDate === yd) {
      streak = streak + 1; // Consecutive day
    } else {
      streak = 1; // First time or broke streak
    }

    localStorage.setItem('nn_bc_streak', String(streak));
    localStorage.setItem('nn_bc_last_date', today);
    return streak;
  }

  function getExistingStreak() {
    var today = getToday();
    var lastDate = localStorage.getItem('nn_bc_last_date');
    var streak = parseInt(localStorage.getItem('nn_bc_streak') || '0', 10);

    if (!lastDate || streak === 0) return 0;

    // Show streak badge on landing if tested yesterday or today
    var yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    var yd = yesterday.toISOString().split('T')[0];

    if (lastDate === today || lastDate === yd) return streak;
    return 0;
  }

  // Show streak badge on landing page if returning user
  (function() {
    var s = getExistingStreak();
    if (s >= 2) {
      $('landing-streak-text').textContent = 'Day ' + s + ' streak';
      $('landing-streak-wrap').style.display = '';
    }
  })();

  // ==================== EMAIL CAPTURE ====================
  var _emailModalShown = false;

  function shouldShowEmailModal() {
    // Don't show if user already subscribed or dismissed recently
    var dismissed = localStorage.getItem('nn_email_dismissed');
    var subscribed = localStorage.getItem('nn_subscribed');
    if (subscribed === '1') return false;
    if (dismissed) {
      var dismissedAt = parseInt(dismissed, 10);
      var sevenDays = 7 * 24 * 60 * 60 * 1000;
      if (Date.now() - dismissedAt < sevenDays) return false;
    }
    return true;
  }

  function showEmailModal() {
    if (_emailModalShown) return;
    if (!shouldShowEmailModal()) return;
    _emailModalShown = true;
    $('email-modal-overlay').classList.add('visible');
    try { gtag('event', 'email_modal_shown', {}); } catch(e) {}
  }

  function hideEmailModal() {
    $('email-modal-overlay').classList.remove('visible');
  }

  function dismissEmailModal() {
    localStorage.setItem('nn_email_dismissed', String(Date.now()));
    hideEmailModal();
    try { gtag('event', 'email_modal_dismissed', {}); } catch(e) {}
  }

  // Show modal after results + 2.5 second delay
  var _origShowResults = showResults;
  // Trigger modal when results screen is shown
  // Poll for results screen becoming active (triggered from showResults → showScreen)
  var _modalScheduled = false;
  (function scheduleModalCheck() {
    var interval = setInterval(function() {
      if ($('results').classList.contains('active') && !_modalScheduled) {
        _modalScheduled = true;
        clearInterval(interval);
        setTimeout(showEmailModal, 2800);
      }
    }, 200);
    // Stop checking after 5 minutes
    setTimeout(function() { clearInterval(interval); }, 300000);
  })();

  $('email-modal-close').addEventListener('click', dismissEmailModal);
  $('email-modal-skip').addEventListener('click', dismissEmailModal);

  $('btn-subscribe').addEventListener('click', function() {
    var emailInput = $('email-modal-input');
    var email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      emailInput.style.borderColor = '#ff4444';
      emailInput.focus();
      setTimeout(function() { emailInput.style.borderColor = ''; }, 2000);
      return;
    }

    var btn = $('btn-subscribe');
    btn.textContent = '...';
    btn.disabled = true;

    fetch('/api/brain-check/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, score: window._currentScore || null })
    })
    .then(function(r) { return r.ok ? r.json() : { ok: false }; })
    .then(function(data) {
      // Mark as subscribed regardless (even if duplicate)
      localStorage.setItem('nn_subscribed', '1');
      $('email-modal-form-wrap').style.display = 'none';
      $('email-modal-success').style.display = '';
      try { gtag('event', 'email_subscribed', { email: email }); } catch(e) {}
      // Auto-close after 3 seconds
      setTimeout(hideEmailModal, 3000);
    })
    .catch(function() {
      btn.textContent = 'Subscribe →';
      btn.disabled = false;
    });
  });

  // Allow submit on Enter key in email input
  $('email-modal-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') $('btn-subscribe').click();
  });

})();
</script>
