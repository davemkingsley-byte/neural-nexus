  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-B0X6HBHKH3');
</script>

<script>
let archiveDates = [];

async function loadArchive() {
  try {
    const res = await fetch('/api/crossword/archive');
    const data = await res.json();
    archiveDates = data.dates || [];
    renderDateList();
    const firstPast = archiveDates.find(d => !d.isToday) || archiveDates[0];
    if (firstPast) loadDate(firstPast.date);
  } catch(e) {
    document.getElementById('dateList').innerHTML = '<div style="color:rgba(255,255,255,0.3);padding:16px;font-size:0.8rem;">Could not load archive</div>';
  }
}

function formatDate(dateStr) {
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

function formatTime(secs) {
  const m = Math.floor(secs / 60);
  const s = secs % 60;
  return `${m}:${String(s).padStart(2,'0')}`;
}

function renderDateList() {
  const list = document.getElementById('dateList');
  if (!archiveDates.length) {
    list.innerHTML = '<div style="color:rgba(255,255,255,0.3);padding:16px;font-size:0.8rem;">No past puzzles yet</div>';
    return;
  }
  list.innerHTML = archiveDates.map(d => `
    <div class="date-item" data-date="${d.date}" onclick="loadDate('${d.date}')">
      <div>
        <div class="date-label">${d.isToday ? '⭐ Today' : formatDate(d.date)}</div>
        ${d.topWord ? `<div class="date-word">${d.topWord}…</div>` : ''}
      </div>
      ${d.hasScores ? '<div class="score-badge">LB</div>' : ''}
    </div>
  `).join('');
}

async function loadDate(dateStr) {
  document.querySelectorAll('.date-item').forEach(el => el.classList.toggle('active', el.dataset.date === dateStr));
  const panel = document.getElementById('detailPanel');
  panel.innerHTML = '<div class="loading"><span class="spinner"></span>Loading...</div>';
  try {
    const res = await fetch(`/api/crossword/archive/${dateStr}`);
    const data = await res.json();
    renderDetail(dateStr, data);
  } catch(e) {
    panel.innerHTML = '<div class="empty-state"><span class="empty-icon">⚠️</span>Could not load data</div>';
  }
}

function renderDetail(dateStr, data) {
  const isToday = dateStr === new Date().toISOString().slice(0, 10);
  const puzzle = data.puzzle;
  const entries = data.entries || [];

  // Build mini grid with cell numbers
  let cellNumbers = {};
  let num = 1;
  if (puzzle && puzzle.grid) {
    for (let r = 0; r < 5; r++) {
      for (let c = 0; c < 5; c++) {
        if (puzzle.grid[r][c] === '#') continue;
        const needsAcross = (c === 0 || puzzle.grid[r][c-1] === '#') && c < 4 && puzzle.grid[r][c+1] !== '#';
        const needsDown = (r === 0 || puzzle.grid[r-1] && puzzle.grid[r-1][c] === '#') && r < 4 && puzzle.grid[r+1] && puzzle.grid[r+1][c] !== '#';
        const atTop = r === 0 || (puzzle.grid[r-1] && puzzle.grid[r-1][c] === '#');
        const atLeft = c === 0 || puzzle.grid[r][c-1] === '#';
        if ((atLeft && c < 4 && puzzle.grid[r][c+1] !== '#') || (atTop && r < 4 && puzzle.grid[r+1] && puzzle.grid[r+1][c] !== '#')) {
          cellNumbers[`${r},${c}`] = num++;
        }
      }
    }
  }

  // Grid HTML
  const gridHtml = puzzle && puzzle.grid ? `
    <div class="mini-grid">
      ${puzzle.grid.flat().map((cell, idx) => {
        const r = Math.floor(idx/5), c = idx%5;
        const cellNum = cellNumbers[`${r},${c}`];
        const showSolution = !isToday;
        return `<div class="mini-cell${cell === '#' ? ' black' : ''}">
          ${cellNum ? `<span class="mini-cell-num">${cellNum}</span>` : ''}
          ${cell !== '#' && showSolution ? cell : ''}
        </div>`;
      }).join('')}
    </div>
  ` : '';

  // Clues HTML
  const cluesHtml = puzzle && puzzle.clues && !isToday ? `
    <div class="archive-clues">
      <div class="clue-section-title">Across</div>
      ${Object.entries(puzzle.clues.across || {}).map(([n,t]) => `
        <div class="clue-row"><span class="clue-num">${n}</span><span>${escHtml(t)}</span></div>
      `).join('')}
      <div class="clue-section-title clue-dir-label">Down</div>
      ${Object.entries(puzzle.clues.down || {}).map(([n,t]) => `
        <div class="clue-row"><span class="clue-num">${n}</span><span>${escHtml(t)}</span></div>
      `).join('')}
    </div>
  ` : (isToday ? '<div style="color:var(--text-dim);font-size:0.82rem;">Solution revealed tomorrow</div>' : '');

  // Stats
  const totalSolvers = entries.length;
  const avgTime = totalSolvers ? Math.round(entries.reduce((s,e) => s + e.time_seconds, 0) / totalSolvers) : null;

  const medals = ['🥇','🥈','🥉'];
  const lbRows = entries.length
    ? entries.map((e, i) => `<tr>
        <td>${i < 3 ? medals[i] : i+1}</td>
        <td>${escHtml(e.nickname)}</td>
        <td>${formatTime(e.time_seconds)}</td>
      </tr>`).join('')
    : '<tr><td colspan="3" class="empty-lb">No scores yet</td></tr>';

  document.getElementById('detailPanel').innerHTML = `
    <div class="puzzle-card">
      <div class="puzzle-date-label">${isToday ? '⭐ Today · ' : ''}${formatDate(dateStr)}</div>
      <div class="archive-game-area">
        ${gridHtml}
        ${cluesHtml}
      </div>
      <div class="puzzle-stats">
        <div class="puzzle-stat">
          <div class="puzzle-stat-val" style="color:var(--accent)">${totalSolvers}</div>
          <div class="puzzle-stat-lbl">Solvers</div>
        </div>
        ${avgTime !== null ? `<div class="puzzle-stat">
          <div class="puzzle-stat-val">${formatTime(avgTime)}</div>
          <div class="puzzle-stat-lbl">Avg Time</div>
        </div>` : ''}
      </div>
    </div>

    <div class="section-head">🏆 Fastest Solvers</div>
    <div class="lb-card">
      <table>
        <thead><tr><th>#</th><th>Player</th><th>Time</th></tr></thead>
        <tbody>${lbRows}</tbody>
      </table>
    </div>
  `;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

loadArchive();
</script>

<nav>
  <div class="nav-left">
    <a href="/" class="nav-brand"><img src="/img/neuron-logo.jpg" alt="Neural NeXus"></a>
    <div class="nav-divider"></div>
    <span class="nav-title">✏️ Crossword Archive</span>
  </div>
  <div class="nav-links">
    <a href="/crossword">Today's Crossword</a>
    <a href="/archive" class="nav-pill">All Archives</a>
    <a href="/">Home</a>
  </div>
</nav>

<main>
  <aside class="sidebar">
    <div class="sidebar-title">Past Puzzles</div>
    <div class="date-list" id="dateList">
      <div class="loading"><span class="spinner"></span>Loading...</div>
    </div>
  </aside>

  <div class="detail-panel" id="detailPanel">
    <div class="empty-state">
      <span class="empty-icon">✏️</span>
      Select a date to see the grid, solution, and leaderboard
    </div>
  </div>
</main>
