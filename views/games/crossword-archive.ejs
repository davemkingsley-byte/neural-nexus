<style>
  :root {
    --bg: #0b0b12;
    --surface: rgba(255,255,255,0.03);
    --surface-2: rgba(255,255,255,0.06);
    --border: rgba(255,255,255,0.06);
    --border-2: rgba(255,255,255,0.1);
    --text: #f0f0f5;
    --text-dim: rgba(255,255,255,0.4);
    --text-mid: rgba(255,255,255,0.6);
    --accent: #7c6aff;
    --accent-dim: rgba(124,106,255,0.15);
    --green: #22c55e;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--bg); color: var(--text);
    font-family: 'DM Sans', -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased; min-height: 100vh;
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(124,106,255,0.07) 0%, transparent 55%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(34,197,94,0.04) 0%, transparent 50%),
      var(--bg);
  }
  nav {
    position: sticky; top: 0; z-index: 50;
    padding: 10px 20px;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(14,14,22,0.95);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .nav-left { display: flex; align-items: center; gap: 10px; }
  .nav-brand { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .nav-brand img { height: 26px; border-radius: 5px; }
  .nav-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.15); }
  .nav-title { font-family: 'Instrument Serif', serif; font-size: 1rem; color: #fff; }
  .nav-links { display: flex; gap: 12px; align-items: center; }
  .nav-links a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.7rem; font-weight: 600; transition: color 0.2s; }
  .nav-links a:hover { color: #fff; }
  .nav-pill { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 6px; }

  main {
    max-width: 940px; margin: 0 auto; padding: 48px 24px 100px;
    display: grid; grid-template-columns: 260px 1fr; gap: 24px; align-items: start;
  }
  .sidebar { position: sticky; top: 68px; }
  .sidebar-title {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); margin-bottom: 12px;
  }
  .date-list { display: flex; flex-direction: column; gap: 4px; max-height: 70vh; overflow-y: auto; }
  .date-item {
    padding: 10px 14px; border-radius: 10px; cursor: pointer;
    border: 1px solid transparent; transition: all 0.2s;
    background: var(--surface);
    display: flex; justify-content: space-between; align-items: center;
  }
  .date-item:hover { background: var(--surface-2); border-color: var(--border); }
  .date-item.active { background: var(--accent-dim); border-color: rgba(124,106,255,0.25); }
  .date-label { font-size: 0.82rem; font-weight: 600; }
  .date-word { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--accent); font-weight: 700; }
  .score-badge { font-size: 0.62rem; font-weight: 700; color: var(--accent); background: var(--accent-dim); padding: 2px 7px; border-radius: 4px; }

  .detail-panel { min-height: 400px; }
  .empty-state { text-align: center; padding: 80px 20px; color: var(--text-dim); font-size: 0.9rem; }
  .empty-icon { font-size: 3rem; display: block; margin-bottom: 14px; }

  .puzzle-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 18px; padding: 28px; margin-bottom: 16px;
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  }
  .puzzle-date-label {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--accent); margin-bottom: 18px;
  }

  .archive-game-area {
    display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-start;
  }

  /* Mini grid */
  .mini-grid {
    display: grid; grid-template-columns: repeat(5, 1fr);
    gap: 2px; background: rgba(255,255,255,0.08); padding: 2px;
    border-radius: 6px; flex-shrink: 0;
  }
  .mini-cell {
    width: 48px; height: 48px; position: relative;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 700;
    color: var(--text); text-transform: uppercase;
  }
  .mini-cell.black { background: rgba(0,0,0,0.5); border-color: transparent; }
  .mini-cell-num {
    position: absolute; top: 2px; left: 3px;
    font-size: 0.45rem; font-weight: 600; color: rgba(255,255,255,0.4); line-height: 1;
  }

  /* Clues */
  .archive-clues { flex: 1; min-width: 180px; }
  .clue-section-title { font-size: 0.6rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
  .clue-row { display: flex; gap: 8px; font-size: 0.78rem; margin-bottom: 5px; color: var(--text-mid); }
  .clue-num { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; font-weight: 700; color: var(--accent); min-width: 16px; }
  .clue-dir-label { margin-top: 14px; }

  .puzzle-stats { display: flex; gap: 24px; flex-wrap: wrap; margin-top: 20px; }
  .puzzle-stat { text-align: center; }
  .puzzle-stat-val { font-family: 'JetBrains Mono', monospace; font-size: 1.4rem; font-weight: 700; }
  .puzzle-stat-lbl { font-size: 0.6rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.8px; margin-top: 2px; }

  .section-head {
    font-size: 0.62rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
    color: var(--text-dim); margin-bottom: 12px; margin-top: 20px;
  }
  .lb-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  }
  table { width: 100%; border-collapse: collapse; }
  th { text-align: left; font-size: 0.58rem; font-weight: 700; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 1px; padding: 10px 14px; border-bottom: 1px solid var(--border); }
  td { padding: 10px 14px; font-size: 0.82rem; color: var(--text-mid); border-bottom: 1px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tr:first-child td { color: var(--accent); font-weight: 700; }
  .empty-lb { text-align: center; color: var(--text-dim); font-size: 0.8rem; padding: 24px; }

  .loading { text-align: center; padding: 60px; color: var(--text-dim); font-size: 0.85rem; }
  .spinner { display: inline-block; width: 22px; height: 22px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin-right: 10px; vertical-align: middle; }
  @keyframes spin { to { transform: rotate(360deg); } }
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

  @media (max-width: 700px) {
    main { grid-template-columns: 1fr; padding: 24px 16px 80px; }
    .sidebar { position: static; }
    .date-list { flex-direction: row; flex-wrap: nowrap; overflow-x: auto; overflow-y: hidden; gap: 8px; max-height: none; }
    .date-item { flex-shrink: 0; min-width: 120px; }
    .archive-game-area { flex-direction: column; }
    .mini-cell { width: 40px; height: 40px; font-size: 0.9rem; }
  }
</style>

