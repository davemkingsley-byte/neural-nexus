<style>
  :root {
    --bg: #08080f;
    --surface: rgba(255,255,255,0.03);
    --surface-2: rgba(255,255,255,0.06);
    --border: rgba(255,255,255,0.06);
    --border-2: rgba(255,255,255,0.1);
    --text: #f0f0f5;
    --text-dim: rgba(255,255,255,0.4);
    --text-mid: rgba(255,255,255,0.6);
    --gold: #f0c040;
    --gold-dim: rgba(240,192,64,0.15);
    --green: #34d399;
    --blue: #60a5fa;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--bg); color: var(--text);
    font-family: 'DM Sans', -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased; min-height: 100vh;
  }
  body::before {
    content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(240,192,64,0.04) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(96,165,250,0.03) 0%, transparent 50%);
  }
  nav {
    position: sticky; top: 0; z-index: 50;
    padding: 12px 20px;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(8,8,15,0.9);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-left { display: flex; align-items: center; gap: 10px; }
  .nav-brand { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .nav-brand img { height: 26px; border-radius: 5px; }
  .nav-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.15); }
  .nav-title {
    font-family: 'Instrument Serif', serif; font-size: 1rem;
    background: linear-gradient(135deg, var(--gold), #ffe4a0);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .nav-links { display: flex; gap: 12px; align-items: center; }
  .nav-links a { color: var(--text-dim); text-decoration: none; font-size: 0.7rem; font-weight: 600; transition: color 0.2s; }
  .nav-links a:hover { color: var(--text); }
  .nav-pill { background: rgba(255,255,255,0.06); border: 1px solid var(--border); padding: 4px 10px; border-radius: 6px; }

  main {
    position: relative; z-index: 1;
    max-width: 900px; margin: 0 auto; padding: 48px 24px 100px;
    display: grid; grid-template-columns: 280px 1fr; gap: 24px; align-items: start;
  }
  .sidebar { position: sticky; top: 80px; }
  .sidebar-title {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 12px;
  }
  .date-list { display: flex; flex-direction: column; gap: 4px; max-height: 70vh; overflow-y: auto; }
  .date-item {
    padding: 10px 14px; border-radius: 10px; cursor: pointer;
    border: 1px solid transparent; transition: all 0.2s;
    display: flex; justify-content: space-between; align-items: center;
    background: var(--surface);
  }
  .date-item:hover { background: var(--surface-2); border-color: var(--border); }
  .date-item.active { background: var(--gold-dim); border-color: rgba(240,192,64,0.25); }
  .date-item .date-label { font-size: 0.82rem; font-weight: 600; }
  .date-item .date-sub { font-size: 0.65rem; color: var(--text-dim); }
  .date-item .score-badge {
    font-size: 0.62rem; font-weight: 700; color: var(--gold);
    background: rgba(240,192,64,0.1); padding: 2px 7px; border-radius: 4px;
  }

  .detail-panel { min-height: 400px; }
  .empty-state {
    text-align: center; padding: 80px 20px;
    color: var(--text-dim); font-size: 0.9rem;
  }
  .empty-icon { font-size: 3rem; display: block; margin-bottom: 14px; }

  .puzzle-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 18px; padding: 28px; margin-bottom: 16px;
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  }
  .puzzle-date-label {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--gold); margin-bottom: 14px;
  }
  .hex-display {
    display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px;
  }
  .hex-letter {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    clip-path: polygon(50% 0%, 93% 25%, 93% 75%, 50% 100%, 7% 75%, 7% 25%);
    font-size: 1rem; font-weight: 800; text-transform: uppercase;
    background: rgba(255,255,255,0.05);
  }
  .hex-letter.center {
    background: linear-gradient(135deg, #f5d56a, #c8960a);
    color: #1a1000;
  }
  .puzzle-stats { display: flex; gap: 20px; flex-wrap: wrap; }
  .puzzle-stat { text-align: center; }
  .puzzle-stat-val {
    font-family: 'JetBrains Mono', monospace; font-size: 1.4rem; font-weight: 700; color: var(--text);
  }
  .puzzle-stat-lbl { font-size: 0.6rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.8px; margin-top: 2px; }

  .section-head {
    font-size: 0.62rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
    color: var(--text-dim); margin-bottom: 12px; margin-top: 20px;
  }
  .lb-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  }
  table { width: 100%; border-collapse: collapse; }
  th {
    text-align: left; font-size: 0.58rem; font-weight: 700; color: rgba(255,255,255,0.25);
    text-transform: uppercase; letter-spacing: 1px; padding: 10px 14px;
    border-bottom: 1px solid var(--border);
  }
  td { padding: 10px 14px; font-size: 0.82rem; color: var(--text-mid); border-bottom: 1px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tr:first-child td { color: var(--gold); font-weight: 700; }
  .empty-lb { text-align: center; color: var(--text-dim); font-size: 0.8rem; padding: 24px; }

  .loading { text-align: center; padding: 60px; color: var(--text-dim); font-size: 0.85rem; }
  .spinner {
    display: inline-block; width: 22px; height: 22px; border: 2px solid var(--border);
    border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite;
    margin-right: 10px; vertical-align: middle;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

  @media (max-width: 700px) {
    main { grid-template-columns: 1fr; padding: 24px 16px 80px; }
    .sidebar { position: static; }
    .date-list { max-height: 200px; flex-direction: row; flex-wrap: nowrap; overflow-x: auto; overflow-y: hidden; gap: 8px; }
    .date-item { flex-shrink: 0; }
  }
</style>

