<script>
let archiveData = [];

async function loadArchive() {
  try {
    const res = await fetch('/api/spelling-bee/archive');
    const data = await res.json();
    archiveData = data.puzzles || [];
    renderDateList();
    if (archiveData.length) loadDate(archiveData[0].date);
  } catch(e) {
    document.getElementById('dateList').innerHTML = '<div style="color:rgba(255,255,255,0.3);padding:16px;font-size:0.8rem;">Could not load archive</div>';
  }
}

function formatDate(dateStr) {
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

function renderDateList() {
  const today = new Date().toISOString().slice(0, 10);
  const list = document.getElementById('dateList');
  if (!archiveData.length) {
    list.innerHTML = '<div style="color:rgba(255,255,255,0.3);padding:16px;font-size:0.8rem;">No past puzzles yet</div>';
    return;
  }
  list.innerHTML = archiveData.map(p => `
    <div class="date-item" data-date="${p.date}" onclick="loadDate('${p.date}')">
      <div>
        <div class="date-label">${p.date === today ? '⭐ Today' : formatDate(p.date)}</div>
        <div class="date-sub">${p.letters || ''}</div>
      </div>
      ${p.entry_count > 0 ? `<div class="score-badge">${p.entry_count}</div>` : ''}
    </div>
  `).join('');
}

async function loadDate(dateStr) {
  // Mark active
  document.querySelectorAll('.date-item').forEach(el => el.classList.toggle('active', el.dataset.date === dateStr));

  const panel = document.getElementById('detailPanel');
  panel.innerHTML = '<div class="loading"><span class="spinner"></span>Loading...</div>';

  try {
    const res = await fetch(`/api/spelling-bee/archive/${dateStr}`);
    const data = await res.json();
    renderDetail(dateStr, data);
  } catch(e) {
    panel.innerHTML = '<div class="empty-state"><span class="empty-icon">⚠️</span>Could not load puzzle data</div>';
  }
}

function renderDetail(dateStr, data) {
  const today = new Date().toISOString().slice(0, 10);
  const puzzle = data.puzzle;
  const scores = data.scores || [];
  const letters = puzzle.letters ? puzzle.letters.split('') : [];
  const center = puzzle.center_letter;

  const hexHtml = letters.map(l => `<div class="hex-letter${l === center ? ' center' : ''}">${l}</div>`).join('');
  const medals = ['🥇','🥈','🥉'];

  const lbRows = scores.length
    ? scores.map((s, i) => `<tr>
        <td>${i < 3 ? medals[i] : i+1}</td>
        <td>${escHtml(s.nickname)}</td>
        <td>${s.score}</td>
        <td>${Array.isArray(s.words_found) ? s.words_found.length : 0}</td>
      </tr>`).join('')
    : '<tr><td colspan="4" class="empty-lb">No scores submitted yet</td></tr>';

  const wordList = puzzle.word_list ? JSON.parse(puzzle.word_list) : [];

  document.getElementById('detailPanel').innerHTML = `
    <div class="puzzle-card">
      <div class="puzzle-date-label">${dateStr === today ? '⭐ Today · ' : ''}${formatDate(dateStr)}</div>
      <div class="hex-display">${hexHtml}</div>
      <div class="puzzle-stats">
        <div class="puzzle-stat"><div class="puzzle-stat-val">${puzzle.max_score}</div><div class="puzzle-stat-lbl">Max Score</div></div>
        <div class="puzzle-stat"><div class="puzzle-stat-val">${wordList.length || '—'}</div><div class="puzzle-stat-lbl">Words</div></div>
        <div class="puzzle-stat"><div class="puzzle-stat-val">${scores.length}</div><div class="puzzle-stat-lbl">Players</div></div>
      </div>
    </div>

    <div class="section-head">🏆 Leaderboard</div>
    <div class="lb-card">
      <table>
        <thead><tr><th>#</th><th>Player</th><th>Score</th><th>Words</th></tr></thead>
        <tbody>${lbRows}</tbody>
      </table>
    </div>

    ${dateStr === today ? '' : `
    <div class="section-head" style="margin-top:24px;">📝 Word List</div>
    <div class="puzzle-card">
      <div style="display:flex;flex-wrap:wrap;gap:6px;">
        ${wordList.map(w => `<span style="background:rgba(255,255,255,0.05);padding:4px 10px;border-radius:20px;font-size:0.75rem;color:var(--text-mid)">${w}</span>`).join('')}
      </div>
    </div>
    `}
  `;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

loadArchive();
</script>

<nav>
  <div class="nav-left">
    <a href="/" class="nav-brand"><img src="/img/neuron-logo.jpg" alt="Neural NeXus"></a>
    <div class="nav-divider"></div>
    <span class="nav-title">🐝 Spelling Bee Archive</span>
  </div>
  <div class="nav-links">
    <a href="/play">Today's Bee</a>
    <a href="/archive" class="nav-pill">All Archives</a>
    <a href="/">Home</a>
  </div>
</nav>

<main>
  <aside class="sidebar">
    <div class="sidebar-title">Past Puzzles</div>
    <div class="date-list" id="dateList">
      <div class="loading"><span class="spinner"></span>Loading...</div>
    </div>
  </aside>

  <div class="detail-panel" id="detailPanel">
    <div class="empty-state">
      <span class="empty-icon">🐝</span>
      Select a date to see that day's puzzle and leaderboard
    </div>
  </div>
</main>
