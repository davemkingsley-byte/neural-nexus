<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #08080f;
  --text: #f0f0f5;
  --accent: #7c6aff;
  --accent-dim: rgba(124,106,255,0.15);
  --accent-glow: rgba(124,106,255,0.4);
  --gold: #f0c040;
  --gold-dim: rgba(240,192,64,0.25);
  --gold-glow: rgba(240,192,64,0.4);
  --blue-highlight: rgba(96,165,250,0.18);
  --blue-border: rgba(96,165,250,0.35);
  --green: #22c55e;
  --green-dim: rgba(34,197,94,0.2);
  --red: #ef4444;
  --cell-bg: rgba(255,255,255,0.07);
  --cell-border: rgba(255,255,255,0.15);
  --black-cell: rgba(0,0,0,0.7);
  --card-bg: rgba(255,255,255,0.04);
  --card-border: rgba(255,255,255,0.08);
}
html, body { height: 100%; }
body {
  background: var(--bg); color: var(--text);
  font-family: 'DM Sans', -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased; overflow-x: hidden;
}
/* Animated ambient background */
body::before {
  content: '';
  position: fixed; top: -50%; left: -50%; width: 200%; height: 200%;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(124,106,255,0.05) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 80%, rgba(34,197,94,0.04) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, rgba(96,165,250,0.03) 0%, transparent 60%);
  animation: ambientShift 20s ease-in-out infinite alternate;
  pointer-events: none; z-index: 0;
}
body::after {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.015'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 0;
}
@keyframes ambientShift {
  0% { transform: translate(0, 0) rotate(0deg); }
  100% { transform: translate(-2%, -1%) rotate(3deg); }
}

/* Nav */
nav {
  position: sticky; top: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 20px; height: 52px;
  background: rgba(14,14,22,0.95);
  border-bottom: 1px solid rgba(255,255,255,0.1);
  backdrop-filter: blur(12px);
}
.nav-left { display: flex; align-items: center; gap: 12px; }
.nav-brand img { height: 32px; border-radius: 6px; }
.nav-divider { width: 1px; height: 24px; background: rgba(255,255,255,0.15); }
.nav-title { font-family: 'Instrument Serif', serif; font-size: 1.25rem; color: #fff; }
.nav-links { display: flex; gap: 8px; }
.nav-links a {
  color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.82rem;
  padding: 6px 12px; border-radius: 8px; transition: all 0.2s;
}
.nav-links a:hover { color: #fff; background: rgba(255,255,255,0.08); }
.nav-pill { background: rgba(255,255,255,0.06) !important; }

/* Layout */
main {
  max-width: 860px; margin: 0 auto; padding: 20px 16px 80px;
  display: flex; flex-direction: column; align-items: center;
}
.game-header { text-align: center; margin-bottom: 12px; }
.game-header h1 {
  font-family: 'Instrument Serif', serif; font-size: 1.8rem;
  background: linear-gradient(135deg, var(--accent) 0%, #c4b5fd 50%, var(--accent) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; background-size: 200% auto;
  animation: shimmer 4s linear infinite;
}
@keyframes shimmer {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}
.game-subtitle { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 4px; }

/* Controls bar */
.controls-bar {
  display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
  font-family: 'JetBrains Mono', monospace;
}
.timer { font-size: 1.1rem; color: var(--accent); min-width: 55px; text-align: center; font-weight: 600; }
.btn {
  padding: 6px 14px; border-radius: 8px; border: 1px solid var(--card-border);
  background: var(--card-bg); color: var(--text); font-size: 0.78rem;
  cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.2s;
  position: relative;
}
.btn:hover { background: rgba(255,255,255,0.1); }

/* Reveal dropdown */
.reveal-wrap { position: relative; }
.reveal-menu {
  display: none; position: absolute; top: 100%; left: 0; margin-top: 4px;
  background: #1a1a2e; border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px; overflow: hidden; min-width: 160px; z-index: 50;
  box-shadow: 0 8px 24px rgba(0,0,0,0.5);
}
.reveal-menu.show { display: block; }
.reveal-option {
  display: block; width: 100%; padding: 10px 14px; border: none;
  background: none; color: var(--text); font-size: 0.8rem; text-align: left;
  cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background 0.15s;
}
.reveal-option:hover { background: rgba(255,255,255,0.08); }
.reveal-option.danger { color: var(--red); }

/* Active clue bar */
.clue-bar {
  width: 100%; max-width: 520px; margin-bottom: 10px;
  display: flex; align-items: center; gap: 10px;
  padding: 10px 14px; border-radius: 10px;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
  min-height: 42px; cursor: pointer;
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  transition: border-color 0.3s, box-shadow 0.3s;
  box-shadow: 0 0 20px rgba(124,106,255,0.05);
}
.clue-bar-badge {
  font-size: 0.6rem; font-weight: 800; letter-spacing: 1.5px;
  text-transform: uppercase; padding: 3px 8px; border-radius: 4px;
  background: var(--accent-dim); color: var(--accent);
  white-space: nowrap; flex-shrink: 0;
}
.clue-bar-text {
  font-size: 0.88rem; color: rgba(255,255,255,0.85); line-height: 1.3;
}

/* Game area */
.game-area {
  display: flex; gap: 24px; width: 100%; justify-content: center;
  align-items: flex-start; flex-wrap: wrap;
}

/* Grid */
.grid-container { position: relative; }
.grid {
  display: grid; grid-template-columns: repeat(5, 1fr);
  gap: 2px; background: rgba(255,255,255,0.12); padding: 2px;
  border-radius: 10px; overflow: hidden;
  box-shadow: 0 0 40px rgba(124,106,255,0.06);
}
.cell {
  width: clamp(50px, 12vw, 68px); height: clamp(50px, 12vw, 68px);
  position: relative; background: var(--cell-bg);
  border: 1.5px solid var(--cell-border);
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Sans', sans-serif; font-size: clamp(1.1rem, 3vw, 1.5rem);
  font-weight: 700; color: var(--text); cursor: pointer;
  transition: background 0.12s, border-color 0.12s;
  text-transform: uppercase; user-select: none;
}
.cell.black {
  background: var(--black-cell); cursor: default;
  border-color: rgba(0,0,0,0.5);
}
.cell.word-highlight {
  background: var(--blue-highlight);
  border-color: var(--blue-border);
  box-shadow: 0 0 8px rgba(96,165,250,0.1);
}
.cell.selected {
  background: var(--gold-dim) !important;
  border-color: var(--gold) !important;
  box-shadow: 0 0 16px var(--gold-glow), inset 0 0 12px rgba(240,192,64,0.15);
  filter: drop-shadow(0 0 6px rgba(240,192,64,0.25));
}
.cell.checked-wrong {
  border-bottom: 3px solid var(--red) !important;
}
.cell.solved-reveal {
  background: var(--green-dim) !important;
  border-color: rgba(34,197,94,0.4) !important;
  box-shadow: 0 0 12px rgba(34,197,94,0.2);
  transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
.cell.revealed-cell {
  color: rgba(255,255,255,0.5);
}
.cell-number {
  position: absolute; top: 3px; left: 4px;
  font-size: 0.65rem; font-weight: 700; color: rgba(255,255,255,0.7);
  line-height: 1; pointer-events: none;
}
.cell-letter { pointer-events: none; }

/* Shake animation for wrong check */
@keyframes cellShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-3px); }
  75% { transform: translateX(3px); }
}
.cell.shake { animation: cellShake 0.3s ease; }

/* Clues */
.clues-container {
  display: flex; flex-direction: column; gap: 14px;
  min-width: 220px; max-width: 300px; flex: 1;
}
.clue-section {
  background: var(--card-bg); border: 1px solid var(--card-border);
  border-radius: 12px; padding: 12px; backdrop-filter: blur(8px);
}
.clue-section h3 {
  font-family: 'Instrument Serif', serif; font-size: 0.95rem;
  margin-bottom: 6px; color: var(--accent);
}
.clue {
  padding: 6px 8px; border-radius: 6px; cursor: pointer;
  font-size: 0.82rem; line-height: 1.4; transition: all 0.12s;
  color: rgba(255,255,255,0.65); display: flex; gap: 8px;
}
.clue:hover { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.9); }
.clue.active {
  background: var(--blue-highlight); color: #fff;
  border-left: 2px solid var(--accent);
}
.clue-num {
  font-weight: 700; color: var(--accent); min-width: 18px;
  font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
}

/* Completion overlay */
.overlay {
  display: none; position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.75); backdrop-filter: blur(8px);
  align-items: center; justify-content: center;
}
.overlay.show { display: flex; }
.overlay-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%);
  border: 1px solid var(--card-border);
  border-radius: 18px; padding: 28px 24px; text-align: center;
  max-width: 380px; width: 92%; max-height: 90vh; overflow-y: auto;
  box-shadow: 0 25px 60px rgba(0,0,0,0.5);
  animation: overlayReveal 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
}
@keyframes overlayReveal {
  0% { opacity: 0; transform: scale(0.85) translateY(30px); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}
.overlay-card h2 {
  font-family: 'Instrument Serif', serif; font-size: 1.6rem; margin-bottom: 6px;
}
.overlay-card .time-result {
  font-family: 'JetBrains Mono', monospace; font-size: 2rem;
  color: var(--green); margin: 10px 0;
}
.overlay-card .stats-row {
  display: flex; justify-content: center; gap: 20px; margin: 14px 0;
}
.stat-item { text-align: center; }
.stat-value { font-size: 1.4rem; font-weight: 700; }
.stat-label { font-size: 0.68rem; color: rgba(255,255,255,0.45); }
.share-btn {
  padding: 10px 28px; border-radius: 10px; border: none;
  background: var(--accent); color: #fff; font-size: 0.9rem;
  font-weight: 600; cursor: pointer; margin-top: 10px;
  font-family: 'DM Sans', sans-serif; transition: all 0.2s;
}
.share-btn:hover { filter: brightness(1.15); }
.share-btn.copied { background: var(--green); }
.nickname-row { display: flex; gap: 8px; margin-top: 12px; }
.nickname-in {
  flex: 1; padding: 10px 14px; border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04);
  color: #fff; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; outline: none;
}
.nickname-in:focus { border-color: rgba(124,106,255,0.4); }
.submit-lb-btn {
  padding: 10px 16px; border-radius: 10px; border: none;
  background: var(--accent); color: #fff;
  font-family: 'DM Sans', sans-serif; font-size: 0.8rem; font-weight: 700;
  cursor: pointer; white-space: nowrap;
}
.submit-lb-btn:disabled { opacity: 0.4; cursor: default; }
.cw-lb-section { margin-top: 12px; text-align: left; }
.cw-lb-title { font-size: 0.85rem; font-weight: 700; margin-bottom: 8px; text-align: center; }
.cw-lb-list { display: flex; flex-direction: column; gap: 4px; max-height: 180px; overflow-y: auto; }
.cw-lb-row { display: flex; justify-content: space-between; padding: 6px 10px; border-radius: 8px; background: rgba(255,255,255,0.03); font-size: 0.78rem; align-items: center; }
.cw-lb-row:first-child { background: rgba(124,106,255,0.1); color: var(--accent); font-weight: 700; }
.cw-lb-name { color: rgba(255,255,255,0.6); }
.cw-lb-time { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: rgba(255,255,255,0.4); }
.overlay-links { display: flex; gap: 8px; justify-content: center; margin-top: 12px; flex-wrap: wrap; }
.overlay-link {
  padding: 8px 14px; border-radius: 8px; text-decoration: none;
  font-size: 0.72rem; font-weight: 700; transition: all 0.2s;
  border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.04);
}
.overlay-link:hover { color: #fff; background: rgba(255,255,255,0.08); }

/* Toast */
#toast {
  position: fixed; top: 64px; left: 50%; transform: translateX(-50%);
  background: var(--text); color: var(--bg); padding: 8px 18px;
  border-radius: 8px; font-weight: 600; font-size: 0.82rem;
  opacity: 0; pointer-events: none; transition: opacity 0.2s; z-index: 250;
}
#toast.show { opacity: 1; }

/* Subscribe CTA */
.game-subscribe-cta {
  width: min(100%, 520px); margin: 8px auto 0; padding: 12px 14px;
  background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px; display: flex; align-items: center; justify-content: center; gap: 8px; text-align: center;
}
.game-subscribe-copy { font-size: 0.76rem; color: rgba(255,255,255,0.58); }
.game-subscribe-button {
  color: rgba(124,106,255,0.9); text-decoration: none; font-size: 0.76rem;
  font-weight: 700; white-space: nowrap; transition: color 0.2s;
}
.game-subscribe-button:hover { color: rgba(196,181,253,0.98); }

/* Mobile */
@media (max-width: 768px) {
  .game-area { flex-direction: column; align-items: center; }
  .clues-container { max-width: 100%; min-width: 0; width: 100%; flex-direction: row; }
  .clue-section { flex: 1; }
  .clue-bar { max-width: 100%; }
}
@media (max-width: 480px) {
  main { padding: 14px 10px 60px; }
  .clues-container { flex-direction: column; }
  .clue-bar { padding: 8px 12px; }
  .clue-bar-text { font-size: 0.82rem; }
  .controls-bar { gap: 8px; }
}
@media (max-width: 380px) {
  .cell { width: clamp(44px, 17vw, 50px); height: clamp(44px, 17vw, 50px); font-size: 1rem; }
  .cell-number { font-size: 0.55rem; }
}

/* Premium polish */
.share-btn:hover { box-shadow: 0 6px 24px rgba(124,106,255,0.35); transform: translateY(-1px); }
.submit-lb-btn:hover { box-shadow: 0 4px 20px rgba(124,106,255,0.3); transform: translateY(-1px); }
.clue.active { box-shadow: 0 0 8px rgba(96,165,250,0.1); }
.confetti-piece {
  position: fixed; top: -10px; z-index: 300; pointer-events: none; border-radius: 2px;
  animation: confettiFall var(--fall-duration, 3s) cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}
@keyframes confettiFall {
  0% { opacity: 1; transform: translateY(0) rotate(0deg) scale(1); }
  80% { opacity: 1; }
  100% { opacity: 0; transform: translateY(100vh) rotate(var(--rotate, 720deg)) scale(0.5); }
}
::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

/* Hidden input for mobile keyboard */
#hiddenInput {
  position: absolute; opacity: 0; width: 1px; height: 1px; top: -100px; left: -100px;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {

// ═══════════════ STATE ═══════════════
let puzzle = null;
let userGrid = [];
let selectedCell = null;
let direction = 'across';
let seconds = 0;
let timerInterval = null;
let started = false;
let solved = false;
let usedReveal = false;
let checkedWrong = new Set();
let todayStr = '';
let clueMap = { across: {}, down: {} };

// ═══════════════ INIT ═══════════════
async function init() {
  try {
    const res = await fetch('/api/crossword/today');
    if (res.ok) {
      const data = await res.json();
      todayStr = data.date || getTodayStr();
      puzzle = data.puzzle || data;
    }
  } catch (e) {}

  if (!puzzle) {
    // Fallback: load from inline if API fails
    todayStr = getTodayStr();
    return;
  }

  // Init user grid
  userGrid = puzzle.grid.map(row => row.map(c => c === '#' ? '#' : ''));

  // Build clue map (clue number -> {row, col, direction, length})
  buildClueMap();

  // Try restore saved state
  const saved = loadState();
  if (saved && saved.date === todayStr) {
    userGrid = saved.userGrid;
    seconds = saved.seconds || 0;
    started = saved.started || false;
    usedReveal = saved.usedReveal || false;
    checkedWrong = new Set(saved.checkedWrong || []);
    if (saved.solved) { solved = true; }
    updateTimerDisplay();
    if (started && !solved) startTimer();
  }

  renderGrid();
  renderClues();

  // Select first cell
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] !== '#') {
        selectCell(r, c);
        return;
      }
    }
  }
}

function getTodayStr() {
  return new Date().toLocaleDateString('en-CA');
}

// ═══════════════ CLUE MAP ═══════════════
function buildClueMap() {
  clueMap = { across: {}, down: {} };
  let num = 0;
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] === '#') continue;
      const startsAcross = (c === 0 || puzzle.grid[r][c - 1] === '#') && c < 4 && puzzle.grid[r][c + 1] !== '#';
      const startsDown = (r === 0 || puzzle.grid[r - 1][c] === '#') && r < 4 && puzzle.grid[r + 1][c] !== '#';
      if (startsAcross || startsDown) {
        num++;
        if (startsAcross) {
          let len = 0;
          for (let cc = c; cc < 5 && puzzle.grid[r][cc] !== '#'; cc++) len++;
          clueMap.across[num] = { row: r, col: c, len, num };
        }
        if (startsDown) {
          let len = 0;
          for (let rr = r; rr < 5 && puzzle.grid[rr][c] !== '#'; rr++) len++;
          clueMap.down[num] = { row: r, col: c, len, num };
        }
      }
    }
  }
}

function getCellNumber(r, c) {
  let num = 0;
  for (let rr = 0; rr < 5; rr++) {
    for (let cc = 0; cc < 5; cc++) {
      if (puzzle.grid[rr][cc] === '#') continue;
      const startsAcross = (cc === 0 || puzzle.grid[rr][cc - 1] === '#') && cc < 4 && puzzle.grid[rr][cc + 1] !== '#';
      const startsDown = (rr === 0 || puzzle.grid[rr - 1] && puzzle.grid[rr - 1][cc] === '#' || rr === 0) && rr < 4 && puzzle.grid[rr + 1][cc] !== '#';
      const startsDownFixed = (rr === 0 || puzzle.grid[rr - 1][cc] === '#') && rr < 4 && puzzle.grid[rr + 1][cc] !== '#';
      if (startsAcross || startsDownFixed) {
        num++;
        if (rr === r && cc === c) return num;
      }
    }
  }
  return null;
}

// Get word cells for a given cell and direction
function getWordCells(r, c, dir) {
  const cells = [];
  if (dir === 'across') {
    let start = c;
    while (start > 0 && puzzle.grid[r][start - 1] !== '#') start--;
    for (let cc = start; cc < 5 && puzzle.grid[r][cc] !== '#'; cc++) {
      cells.push([r, cc]);
    }
  } else {
    let start = r;
    while (start > 0 && puzzle.grid[start - 1][c] !== '#') start--;
    for (let rr = start; rr < 5 && puzzle.grid[rr][c] !== '#'; rr++) {
      cells.push([rr, c]);
    }
  }
  return cells;
}

// Get the clue for current selection
function getActiveClue() {
  if (!selectedCell) return null;
  const [r, c] = selectedCell;
  const wordCells = getWordCells(r, c, direction);
  if (wordCells.length < 2) return null;
  const [startR, startC] = wordCells[0];
  const num = getCellNumber(startR, startC);
  if (!num) return null;
  const clueText = puzzle.clues[direction]?.[num];
  return clueText ? { num, text: clueText, direction } : null;
}

// ═══════════════ RENDER ═══════════════
function renderGrid() {
  const grid = document.getElementById('grid');
  grid.innerHTML = '';
  const wordCells = selectedCell ? getWordCells(selectedCell[0], selectedCell[1], direction) : [];
  const wordSet = new Set(wordCells.map(([r, c]) => `${r},${c}`));

  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      const cell = document.createElement('div');
      cell.className = 'cell';
      cell.dataset.row = r;
      cell.dataset.col = c;

      if (puzzle.grid[r][c] === '#') {
        cell.classList.add('black');
      } else {
        // Highlighting
        if (selectedCell && selectedCell[0] === r && selectedCell[1] === c) {
          cell.classList.add('selected');
        } else if (wordSet.has(`${r},${c}`)) {
          cell.classList.add('word-highlight');
        }

        // Check feedback
        if (checkedWrong.has(`${r},${c}`)) {
          cell.classList.add('checked-wrong');
        }

        // Revealed cells
        if (cell.dataset.revealed) {
          cell.classList.add('revealed-cell');
        }

        // Solved animation
        if (solved) {
          cell.classList.add('solved-reveal');
        }

        // Cell number
        const num = getCellNumber(r, c);
        if (num) {
          const numEl = document.createElement('span');
          numEl.className = 'cell-number';
          numEl.textContent = num;
          cell.appendChild(numEl);
        }

        // Letter
        const letter = document.createElement('span');
        letter.className = 'cell-letter';
        letter.textContent = userGrid[r][c] || '';
        cell.appendChild(letter);

        // Click handler
        cell.addEventListener('click', () => {
          if (solved) return;
          if (selectedCell && selectedCell[0] === r && selectedCell[1] === c) {
            // Toggle direction
            direction = direction === 'across' ? 'down' : 'across';
          }
          selectCell(r, c);
          focusInput();
        });
      }

      grid.appendChild(cell);
    }
  }

  updateClueBar();
  highlightActiveClue();
}

function renderClues() {
  const acrossDiv = document.getElementById('acrossClues');
  const downDiv = document.getElementById('downClues');
  acrossDiv.innerHTML = '';
  downDiv.innerHTML = '';

  for (const [num, clueText] of Object.entries(puzzle.clues.across || {})) {
    const el = document.createElement('div');
    el.className = 'clue';
    el.dataset.dir = 'across';
    el.dataset.num = num;
    el.innerHTML = `<span class="clue-num">${num}</span><span>${clueText}</span>`;
    el.addEventListener('click', () => {
      direction = 'across';
      const info = clueMap.across[num];
      if (info) selectCell(info.row, info.col);
      focusInput();
    });
    acrossDiv.appendChild(el);
  }

  for (const [num, clueText] of Object.entries(puzzle.clues.down || {})) {
    const el = document.createElement('div');
    el.className = 'clue';
    el.dataset.dir = 'down';
    el.dataset.num = num;
    el.innerHTML = `<span class="clue-num">${num}</span><span>${clueText}</span>`;
    el.addEventListener('click', () => {
      direction = 'down';
      const info = clueMap.down[num];
      if (info) selectCell(info.row, info.col);
      focusInput();
    });
    downDiv.appendChild(el);
  }
}

function highlightActiveClue() {
  document.querySelectorAll('.clue').forEach(el => el.classList.remove('active'));
  const clue = getActiveClue();
  if (clue) {
    const el = document.querySelector(`.clue[data-dir="${clue.direction}"][data-num="${clue.num}"]`);
    if (el) {
      el.classList.add('active');
      el.scrollIntoView({ block: 'nearest' });
    }
  }
}

function updateClueBar() {
  const badge = document.getElementById('clueBarBadge');
  const text = document.getElementById('clueBarText');
  const clue = getActiveClue();
  if (clue) {
    badge.textContent = `${clue.num} ${clue.direction}`;
    text.textContent = clue.text;
  } else {
    badge.textContent = '';
    text.textContent = 'Select a cell to begin';
  }
}

// ═══════════════ SELECTION & INPUT ═══════════════
function selectCell(r, c) {
  if (puzzle.grid[r][c] === '#') return;
  selectedCell = [r, c];

  // If the word in current direction has length < 2, switch direction
  const wordCells = getWordCells(r, c, direction);
  if (wordCells.length < 2) {
    direction = direction === 'across' ? 'down' : 'across';
  }

  renderGrid();
}

function focusInput() {
  document.getElementById('hiddenInput').focus();
}

function handleKey(e) {
  if (solved || !selectedCell) return;
  const [r, c] = selectedCell;
  const key = e.key;

  if (key === 'ArrowUp') { e.preventDefault(); moveDir(-1, 0); }
  else if (key === 'ArrowDown') { e.preventDefault(); moveDir(1, 0); }
  else if (key === 'ArrowLeft') { e.preventDefault(); moveDir(0, -1); }
  else if (key === 'ArrowRight') { e.preventDefault(); moveDir(0, 1); }
  else if (key === 'Tab') {
    e.preventDefault();
    direction = direction === 'across' ? 'down' : 'across';
    selectCell(r, c);
  }
  else if (key === ' ') {
    e.preventDefault();
    direction = direction === 'across' ? 'down' : 'across';
    selectCell(r, c);
  }
  else if (key === 'Backspace' || key === 'Delete') {
    e.preventDefault();
    if (!started) startTimer();
    if (userGrid[r][c]) {
      userGrid[r][c] = '';
      checkedWrong.delete(`${r},${c}`);
      renderGrid();
    } else {
      movePrev();
      if (selectedCell) {
        userGrid[selectedCell[0]][selectedCell[1]] = '';
        checkedWrong.delete(`${selectedCell[0]},${selectedCell[1]}`);
        renderGrid();
      }
    }
    saveState();
  }
  else if (/^[a-zA-Z]$/.test(key)) {
    e.preventDefault();
    if (!started) startTimer();
    userGrid[r][c] = key.toUpperCase();
    checkedWrong.delete(`${r},${c}`);
    renderGrid();
    moveNext();
    saveState();
    checkCompletion();
  }
}

function moveNext() {
  if (!selectedCell) return;
  const [r, c] = selectedCell;
  const wordCells = getWordCells(r, c, direction);
  const idx = wordCells.findIndex(([rr, cc]) => rr === r && cc === c);

  // Move to next cell in word
  if (idx < wordCells.length - 1) {
    const [nr, nc] = wordCells[idx + 1];
    selectCell(nr, nc);
    return;
  }

  // Word is full — auto-advance to next unfilled word
  const allClues = [];
  for (const [num, info] of Object.entries(clueMap[direction])) {
    allClues.push({ num: parseInt(num), ...info, dir: direction });
  }
  const otherDir = direction === 'across' ? 'down' : 'across';
  for (const [num, info] of Object.entries(clueMap[otherDir])) {
    allClues.push({ num: parseInt(num), ...info, dir: otherDir });
  }

  // Find current word's clue
  const [startR, startC] = wordCells[0];
  const currentNum = getCellNumber(startR, startC);
  const currentIdx = allClues.findIndex(cl => cl.num === currentNum && cl.dir === direction);

  // Look for next word with empty cells
  for (let i = 1; i < allClues.length; i++) {
    const next = allClues[(currentIdx + i) % allClues.length];
    const nextCells = getWordCells(next.row, next.col, next.dir);
    const hasEmpty = nextCells.some(([rr, cc]) => !userGrid[rr][cc]);
    if (hasEmpty) {
      direction = next.dir;
      // Find first empty cell in word
      const emptyCell = nextCells.find(([rr, cc]) => !userGrid[rr][cc]);
      if (emptyCell) selectCell(emptyCell[0], emptyCell[1]);
      return;
    }
  }
}

function movePrev() {
  if (!selectedCell) return;
  const [r, c] = selectedCell;
  const wordCells = getWordCells(r, c, direction);
  const idx = wordCells.findIndex(([rr, cc]) => rr === r && cc === c);
  if (idx > 0) {
    const [nr, nc] = wordCells[idx - 1];
    selectCell(nr, nc);
  }
}

function moveDir(dr, dc) {
  if (!selectedCell) return;
  let [r, c] = selectedCell;

  // Switch direction to match arrow
  if (dr !== 0 && direction === 'across') { direction = 'down'; selectCell(r, c); return; }
  if (dc !== 0 && direction === 'down') { direction = 'across'; selectCell(r, c); return; }

  r += dr; c += dc;
  while (r >= 0 && r < 5 && c >= 0 && c < 5) {
    if (puzzle.grid[r][c] !== '#') { selectCell(r, c); return; }
    r += dr; c += dc;
  }
}

// ═══════════════ TIMER ═══════════════
function startTimer() {
  if (started) return;
  started = true;
  timerInterval = setInterval(() => {
    seconds++;
    updateTimerDisplay();
    // Save every 5 seconds
    if (seconds % 5 === 0) saveState();
  }, 1000);
}

function stopTimer() {
  clearInterval(timerInterval);
  timerInterval = null;
}

function updateTimerDisplay() {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  document.getElementById('timer').textContent = `${m}:${s.toString().padStart(2, '0')}`;
}

function formatTime(secs) {
  const m = Math.floor(secs / 60);
  const s = secs % 60;
  return `${m}:${s.toString().padStart(2, '0')}`;
}

// ═══════════════ CHECK ═══════════════
function checkPuzzle() {
  if (solved) return;
  let allCorrect = true;
  checkedWrong.clear();

  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] === '#' || !userGrid[r][c]) continue;
      if (userGrid[r][c] !== puzzle.grid[r][c]) {
        checkedWrong.add(`${r},${c}`);
        allCorrect = false;
        // Shake animation
        const cell = document.querySelector(`.cell[data-row="${r}"][data-col="${c}"]`);
        if (cell) {
          cell.classList.add('shake');
          setTimeout(() => cell.classList.remove('shake'), 300);
        }
      }
    }
  }

  renderGrid();
  saveState();

  if (allCorrect && isGridFull()) {
    showToast('All correct!');
  } else if (!allCorrect) {
    showToast('Some letters are wrong');
  }
}

// ═══════════════ REVEAL ═══════════════
function revealLetter() {
  if (solved || !selectedCell) return;
  const [r, c] = selectedCell;
  if (puzzle.grid[r][c] === '#') return;
  userGrid[r][c] = puzzle.grid[r][c];
  usedReveal = true;
  checkedWrong.delete(`${r},${c}`);
  renderGrid();
  moveNext();
  saveState();
  checkCompletion();
  closeRevealMenu();
}

function revealWord() {
  if (solved || !selectedCell) return;
  const wordCells = getWordCells(selectedCell[0], selectedCell[1], direction);
  wordCells.forEach(([r, c]) => {
    userGrid[r][c] = puzzle.grid[r][c];
    checkedWrong.delete(`${r},${c}`);
  });
  usedReveal = true;
  renderGrid();
  saveState();
  checkCompletion();
  closeRevealMenu();
}

function revealPuzzle() {
  if (solved) return;
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] !== '#') userGrid[r][c] = puzzle.grid[r][c];
    }
  }
  usedReveal = true;
  checkedWrong.clear();
  renderGrid();
  saveState();
  checkCompletion();
  closeRevealMenu();
}

function closeRevealMenu() {
  document.getElementById('revealMenu').classList.remove('show');
}

// ═══════════════ COMPLETION ═══════════════
function isGridFull() {
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] !== '#' && !userGrid[r][c]) return false;
    }
  }
  return true;
}

function checkCompletion() {
  if (solved) return;
  if (!isGridFull()) return;

  // Verify all correct
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] !== '#' && userGrid[r][c] !== puzzle.grid[r][c]) return;
    }
  }

  // Solved!
  solved = true;
  stopTimer();
  saveState();

  // Animate cells green row by row
  let delay = 0;
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] !== '#') {
        setTimeout(() => {
          const cell = document.querySelector(`.cell[data-row="${r}"][data-col="${c}"]`);
          if (cell) cell.classList.add('solved-reveal');
        }, delay);
        delay += 60;
      }
    }
  }

  setTimeout(() => showCompletionOverlay(), delay + 400);
}

function launchConfetti() {
  const colors = ['#7c6aff', '#22c55e', '#eab308', '#60a5fa', '#f472b6', '#ef4444'];
  for (let i = 0; i < 50; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.left = Math.random() * 100 + 'vw';
    piece.style.background = colors[Math.floor(Math.random() * colors.length)];
    piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
    piece.style.width = (Math.random() * 8 + 5) + 'px';
    piece.style.height = (Math.random() * 8 + 5) + 'px';
    piece.style.setProperty('--fall-duration', (Math.random() * 2 + 2) + 's');
    piece.style.setProperty('--rotate', (Math.random() * 720) + 'deg');
    piece.style.animationDelay = (Math.random() * 1.5) + 's';
    document.body.appendChild(piece);
    setTimeout(() => piece.remove(), 5000);
  }
}

function showCompletionOverlay() {
  if (!usedReveal) launchConfetti();
  // Update stats
  const stats = loadStats();
  stats.played++;
  const lastDate = localStorage.getItem('nn-crossword-last-date');
  const yesterday = new Date();
  yesterday.setDate(yesterday.getDate() - 1);
  const yesterdayStr = yesterday.toLocaleDateString('en-CA');
  if (lastDate === yesterdayStr) {
    stats.streak++;
  } else if (lastDate !== todayStr) {
    stats.streak = 1;
  }
  localStorage.setItem('nn-crossword-last-date', todayStr);
  if (!stats.best || seconds < stats.best) stats.best = seconds;
  saveStats(stats);

  document.getElementById('finalTime').textContent = formatTime(seconds);
  document.getElementById('statPlayed').textContent = stats.played;
  document.getElementById('statStreak').textContent = stats.streak;
  document.getElementById('statBest').textContent = stats.best ? formatTime(stats.best) : '—';

  // Hide nickname if used reveal
  const nicknameRow = document.getElementById('nicknameRow');
  if (usedReveal) {
    nicknameRow.style.display = 'none';
    showToast('Revealed puzzles are not eligible for the leaderboard');
  } else {
    const alreadySubmitted = localStorage.getItem('nn-crossword-submitted-' + todayStr);
    if (alreadySubmitted) {
      nicknameRow.style.display = 'none';
    }
  }

  loadLeaderboard();
  document.getElementById('overlay').classList.add('show');
}

// ═══════════════ LEADERBOARD ═══════════════
async function loadLeaderboard() {
  try {
    const res = await fetch(`/api/crossword/leaderboard?date=${todayStr}`);
    const data = await res.json();
    const entries = data.entries || [];
    const medals = ['\u{1F947}', '\u{1F948}', '\u{1F949}'];
    const section = document.getElementById('cwLbSection');
    const list = document.getElementById('cwLbList');
    if (entries.length) {
      list.innerHTML = entries.map((e, i) => `
        <div class="cw-lb-row">
          <span>${i < 3 ? medals[i] : i + 1} <span class="cw-lb-name">${e.nickname.replace(/</g, '&lt;')}</span></span>
          <span class="cw-lb-time">${formatTime(e.time_seconds)}</span>
        </div>
      `).join('');
      section.style.display = 'block';
    }
  } catch (e) {}
}

async function submitScore() {
  const nick = document.getElementById('nicknameInput').value.trim();
  if (!nick) return;
  localStorage.setItem('nn-nickname', nick);
  document.getElementById('submitLbBtn').disabled = true;
  try {
    await fetch('/api/crossword/score', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ date: todayStr, nickname: nick, timeSeconds: seconds, completed: true })
    });
    localStorage.setItem('nn-crossword-submitted-' + todayStr, '1');
    document.getElementById('nicknameRow').style.display = 'none';
    loadLeaderboard();
  } catch (e) {
    showToast('Failed to submit');
    document.getElementById('submitLbBtn').disabled = false;
  }
}

// ═══════════════ SHARE ═══════════════
function shareResult() {
  let grid = '';
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      grid += puzzle.grid[r][c] === '#' ? '\u2B1B' : '\u{1F7E9}';
    }
    grid += '\n';
  }
  const text = `Mini Crossword \u2014 Neural NeXus\n${todayStr}\n\u23F1\uFE0F ${formatTime(seconds)}\n\n${grid}\nhttps://www.neuralnexus.press/crossword`;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('shareBtn');
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Share \u{1F4CB}'; btn.classList.remove('copied'); }, 2000);
    });
  }
}

// ═══════════════ PERSISTENCE ═══════════════
function saveState() {
  const state = {
    date: todayStr,
    userGrid,
    seconds,
    started,
    solved,
    usedReveal,
    checkedWrong: Array.from(checkedWrong)
  };
  localStorage.setItem('nn-crossword-' + todayStr, JSON.stringify(state));
}

function loadState() {
  try {
    const raw = localStorage.getItem('nn-crossword-' + todayStr);
    return raw ? JSON.parse(raw) : null;
  } catch { return null; }
}

function loadStats() {
  try { return JSON.parse(localStorage.getItem('nn-crossword-stats')) || { played: 0, streak: 0, best: null }; }
  catch { return { played: 0, streak: 0, best: null }; }
}
function saveStats(s) { localStorage.setItem('nn-crossword-stats', JSON.stringify(s)); }

// ═══════════════ TOAST ═══════════════
function showToast(msg, duration) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), duration || 1800);
}

// ═══════════════ EVENT LISTENERS ═══════════════
document.addEventListener('keydown', handleKey);

// Mobile hidden input
document.getElementById('hiddenInput').addEventListener('input', (e) => {
  const val = e.target.value;
  if (val && /^[a-zA-Z]$/.test(val)) {
    if (!started) startTimer();
    if (selectedCell && !solved) {
      const [r, c] = selectedCell;
      userGrid[r][c] = val.toUpperCase();
      checkedWrong.delete(`${r},${c}`);
      renderGrid();
      moveNext();
      saveState();
      checkCompletion();
    }
  }
  e.target.value = '';
});

// Check button
document.getElementById('checkBtn').addEventListener('click', checkPuzzle);

// Reveal dropdown
document.getElementById('revealBtn').addEventListener('click', (e) => {
  e.stopPropagation();
  document.getElementById('revealMenu').classList.toggle('show');
});
document.getElementById('revealLetter').addEventListener('click', revealLetter);
document.getElementById('revealWord').addEventListener('click', revealWord);
document.getElementById('revealPuzzle').addEventListener('click', () => {
  if (confirm('Reveal the entire puzzle? This will disqualify you from the leaderboard.')) {
    revealPuzzle();
  }
});

// Close reveal menu on outside click
document.addEventListener('click', () => closeRevealMenu());

// Clue bar click toggles direction
document.getElementById('clueBar').addEventListener('click', () => {
  if (selectedCell && !solved) {
    direction = direction === 'across' ? 'down' : 'across';
    selectCell(selectedCell[0], selectedCell[1]);
  }
});

// Share
document.getElementById('shareBtn').addEventListener('click', shareResult);

// Leaderboard submit
document.getElementById('submitLbBtn').addEventListener('click', submitScore);
document.getElementById('nicknameInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') submitScore();
});

// Pre-fill nickname
const savedNick = localStorage.getItem('nn-nickname');
if (savedNick) document.getElementById('nicknameInput').value = savedNick;

// Close overlay on background click
document.getElementById('overlay').addEventListener('click', (e) => {
  if (e.target === document.getElementById('overlay')) {
    document.getElementById('overlay').classList.remove('show');
  }
});

// Focus grid on page click
document.querySelector('main').addEventListener('click', (e) => {
  if (!e.target.closest('.clues-container') && !e.target.closest('.controls-bar') && !e.target.closest('.reveal-menu')) {
    focusInput();
  }
});

// Fetch puzzle from API
async function fetchPuzzle() {
  try {
    const res = await fetch('/api/crossword/today');
    if (!res.ok) return null;
    const data = await res.json();
    return data;
  } catch { return null; }
}

// Init
(async () => {
  const data = await fetchPuzzle();
  if (data) {
    todayStr = data.date || getTodayStr();
    puzzle = data.puzzle || data;
  }
  if (!puzzle) {
    showToast('Failed to load puzzle');
    return;
  }

  userGrid = puzzle.grid.map(row => row.map(c => c === '#' ? '#' : ''));
  buildClueMap();

  const saved = loadState();
  if (saved && saved.date === todayStr) {
    userGrid = saved.userGrid;
    seconds = saved.seconds || 0;
    started = saved.started || false;
    usedReveal = saved.usedReveal || false;
    checkedWrong = new Set(saved.checkedWrong || []);
    solved = saved.solved || false;
    updateTimerDisplay();
    if (started && !solved) startTimer();
  }

  renderGrid();
  renderClues();

  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      if (puzzle.grid[r][c] !== '#') {
        selectCell(r, c);
        return;
      }
    }
  }
})();

});
</script>

