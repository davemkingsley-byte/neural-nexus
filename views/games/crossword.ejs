  <div class="overlay-card">
    <h2>&#x1F389; Solved!</h2>
    <div class="time-result" id="finalTime">0:00</div>
    <div class="stats-row">
      <div class="stat-item"><div class="stat-value" id="statPlayed">0</div><div class="stat-label">Played</div></div>
      <div class="stat-item"><div class="stat-value" id="statStreak">0</div><div class="stat-label">Streak</div></div>
      <div class="stat-item"><div class="stat-value" id="statBest">&mdash;</div><div class="stat-label">Best</div></div>
    </div>
    <button class="share-btn" id="shareBtn">Share &#x1F4CB;</button>
    <div class="nickname-row" id="nicknameRow">
      <input class="nickname-in" id="nicknameInput" placeholder="Your nickname" maxlength="20" autocomplete="off">
      <button class="submit-lb-btn" id="submitLbBtn">Submit &rarr;</button>
    </div>
    <div class="cw-lb-section" id="cwLbSection" style="display:none">
      <div class="cw-lb-title">&#x1F3C6; Today's Fastest</div>
      <div class="cw-lb-list" id="cwLbList"></div>
    </div>
    <div class="overlay-links">
      <a href="/crossword/archive" class="overlay-link">&#x1F4C5; Archive</a>
      <a href="/play" class="overlay-link">&#x1F41D; Spelling Bee</a>
      <a href="/wordle" class="overlay-link">&#x1F7E9; Wordie</a>
      <a href="/connections" class="overlay-link">&#x1F7EA; Connections</a>
    </div>
  </div>
</div>
